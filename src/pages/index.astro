---
import HeroSection from '../components/HeroSection.astro';
import ProjectsSection from '../components/ProjectsSection.astro';
import Services from '../components/Services.astro';
import TechStack from '../components/TechStack.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';
import Layout from '../layouts/Layout.astro';

const companyName = 'MidnightSystems';
---

<Layout title={`${companyName} | Digital Experience`}>
    <main class="relative w-full bg-[#0a0a0b] overflow-x-hidden">
        
        <section id="hero-wrapper" class="h-screen w-full sticky top-0 z-0 overflow-hidden bg-[#0a0a0b]">
            <HeroSection companyName={companyName} />
        </section>

        <div id="content-container" class="relative z-10 bg-[#0a0a0b]">
            
            <section class="pt-1 lg:pt-5 exit-animate">
                <Services />
            </section>

            <section class="py-1 lg:py-5 exit-animate">
                <TechStack />
            </section>

            <section class="exit-animate">
                <ProjectsSection />
            </section>
            
            <section class=" exit-animate">
                <ContactSection />
            </section>

            <Footer />
        </div>
    </main>
</Layout>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    
    gsap.registerPlugin(ScrollTrigger);

    const initGlobalAnimations = () => {
        // Limpiar triggers previos para evitar duplicados en cambios de página
        ScrollTrigger.getAll().forEach(t => t.kill());

        // 1. PARALLAX DEL HERO (Solo afecta al Hero al bajar)
        gsap.to("#hero-wrapper", {
            scrollTrigger: {
                trigger: "#content-container",
                start: "top bottom", 
                end: "top top",    
                scrub: true,       
            },
            y: 100,                
            scale: 0.9,            
            opacity: 0,            
            filter: "blur(10px)",  
            ease: "none"
        });

        // 2. SOLO ANIMACIÓN DE SALIDA (Exit)
        // No aplicamos animaciones de entrada aquí porque cada componente tiene la suya propia.
        // Esto solo hace que la sección se desvanezca suavemente al alejarse por arriba.
        const exitSections = document.querySelectorAll('.exit-animate');
        
        exitSections.forEach((section) => {
            gsap.to(section, {
                scrollTrigger: {
                    trigger: section,
                    start: "top 5%",      
                    end: "bottom top",   
                    scrub: true,
                },
                opacity: 0,               
                y: -40,                  
                filter: "blur(10px)",
                ease: "none"
            });
        });
        
        ScrollTrigger.refresh();
    };

    document.addEventListener('astro:page-load', initGlobalAnimations);

    // Fallback manual
    if (document.readyState === 'complete') {
        initGlobalAnimations();
    }
</script>

<style>
    :global(html) {
        background-color: #0a0a0b; 
        scrollbar-gutter: stable;
    }

    #content-container {
        background-color: #0a0a0b;
        overflow: visible; 
        margin-top: -1px; 
    }

    /* Solo will-change para rendimiento, sin estados iniciales de opacidad */
    .exit-animate {
        will-change: transform, opacity, filter;
    }
</style>