---
import HeroSection from '../components/HeroSection.astro';
import ProjectsSection from '../components/ProjectsSection.astro';
import Services from '../components/Services.astro';
import TechStack from '../components/TechStack.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';
import Layout from '../layouts/Layout.astro';

const companyName = 'MidnightSystems';
---

<Layout title={`${companyName} | Digital Experience`}>
    <main class="relative w-full bg-[#050505] overflow-x-hidden">
        
        <section id="hero-wrapper" class="h-screen w-full sticky top-0 z-0 overflow-hidden">
            <HeroSection companyName={companyName} />
        </section>

        <div id="content-container" class="relative z-10 bg-[#050505]">
            
            <section class="section-animate pt-20">
                <Services />
            </section>

            <section class="section-animate py-10">
                <TechStack />
            </section>

            <section class="section-animate py-20">
                <ProjectsSection />
            </section>
            
            <section class="section-animate pb-20">
                <ContactSection />
            </section>

            <Footer />
        </div>
    </main>
</Layout>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    
    gsap.registerPlugin(ScrollTrigger);

    const initScrollAnimations = () => {
        ScrollTrigger.refresh();

        // 1. PARALLAX HERO (Se mantiene igual, es la base)
        gsap.to("#hero-wrapper", {
            scrollTrigger: {
                trigger: "#content-container",
                start: "top bottom", 
                end: "top top",    
                scrub: true,       
            },
            y: 150,                
            scale: 0.9,            
            opacity: 0,            
            filter: "blur(15px)",  
            ease: "none"
        });

        // 2. ANIMACIÓN DE SECCIONES (Entrada y Salida)
        const sections = document.querySelectorAll('.section-animate');
        
        sections.forEach((section) => {
            // Timeline para cada sección
            const tl = gsap.timeline({
                scrollTrigger: {
                    trigger: section,
                    start: "top 90%",     // Empieza a entrar cuando el top de la sección está al 90% del viewport
                    end: "bottom 20%",    // Empieza a "desaparecer" cuando el bottom está al 20%
                    toggleActions: "play reverse play reverse", // Animación de entrada y salida
                }
            });

            // Efecto de Entrada y Salida combinado
            tl.fromTo(section, 
                { 
                    autoAlpha: 0, 
                    y: 100, 
                    scale: 0.95,
                    filter: "blur(10px)" 
                },
                { 
                    autoAlpha: 1, 
                    y: 0, 
                    scale: 1,
                    filter: "blur(0px)",
                    duration: 1.2, 
                    ease: "expo.out" 
                }
            );

            // 3. EFECTO DE "ALEJAMIENTO" AL SALIR (Opcional pero recomendado para el look Midnight)
            gsap.to(section, {
                scrollTrigger: {
                    trigger: section,
                    start: "top top",      // Cuando la sección llega al tope de la pantalla
                    end: "bottom top",   // Hasta que sale por completo
                    scrub: true,
                },
                scale: 0.8,               // Se encoge ligeramente
                y: -100,                  // Se desplaza hacia arriba más rápido
                opacity: 0,               // Se desvanece
                filter: "blur(10px)",     // Se desenfoca
                ease: "none"
            });
        });
    };

    document.addEventListener('astro:page-load', initScrollAnimations);
</script>

<style>
    :global(html) {
        background-color: #050505;
        scrollbar-gutter: stable;
    }

    #content-container {
        background: linear-gradient(to bottom, transparent, #050505 10vh);
        box-shadow: 0 -100px 100px rgba(0,0,0,0.9);
        /* Importante para que el efecto de escala no corte los bordes */
        overflow: visible; 
    }

    .section-animate {
        will-change: transform, opacity, filter;
        /* Evita que las secciones se amontonen visualmente durante la escala */
        transform-origin: center center;
    }
</style>