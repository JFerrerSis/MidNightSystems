---
import HeroSection from '../components/HeroSection.astro';
import ProjectsSection from '../components/ProjectsSection.astro';
import Services from '../components/Services.astro';
import TechStack from '../components/TechStack.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';
import Layout from '../layouts/Layout.astro';

const companyName = 'MidnightSystems';
---

<Layout title={`${companyName} | Digital Experience`}>
    <main class="relative w-full bg-[#0a0a0b] overflow-x-hidden">
        
        <section id="hero-wrapper" class="h-screen w-full sticky top-0 z-0 overflow-hidden bg-[#0a0a0b]">
            <HeroSection companyName={companyName} />
        </section>

        <div id="content-container" class="relative z-10 bg-[#0a0a0b]">
            
            <section class="pt-1 lg:pt-5">
                <Services />
            </section>

            <section class="py-1 lg:py-5">
                <TechStack />
            </section>

            <section>
                <ProjectsSection />
            </section>
            
            <section class="py-1 lg:py-5">
                <ContactSection />
            </section>

            <Footer />
        </div>
    </main>
</Layout>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    
    gsap.registerPlugin(ScrollTrigger);

    const initGlobalAnimations = () => {
        // Matamos todo lo anterior para que no haya basura en memoria
        ScrollTrigger.getAll().forEach(t => t.kill());

        // 1. ÚNICA ANIMACIÓN GLOBAL: El Hero desaparece al bajar
        // Esto es necesario porque el Hero es "Sticky" y está fuera de los componentes
        gsap.to("#hero-wrapper", {
            scrollTrigger: {
                trigger: "#content-container",
                start: "top bottom", 
                end: "top top",    
                scrub: true,       
            },
            scale: 0.9,            
            opacity: 0,            
            ease: "none"
        });
        
        ScrollTrigger.refresh();
    };

    document.addEventListener('astro:page-load', initGlobalAnimations);

    if (document.readyState === 'complete') {
        initGlobalAnimations();
    }
</script>

<style>
    :global(html) {
        background-color: #0a0a0b; 
        scrollbar-gutter: stable;
    }

    #content-container {
        background-color: #0a0a0b;
        overflow: visible; 
        margin-top: -1px; 
    }
</style>