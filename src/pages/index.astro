---
import HeroSection from '../components/HeroSection.astro';
import ProjectsSection from '../components/ProjectsSection.astro';
import Services from '../components/Services.astro';
import TechStack from '../components/TechStack.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';
import Layout from '../layouts/Layout.astro';

const companyName = 'MidnightSystems';
---

<Layout>
    <main class="relative w-full">
        <section id="hero-wrapper" class="h-screen w-full overflow-hidden bg-[#0a0a0b] relative z-0">
            <HeroSection companyName={companyName} />
        </section>

        <div id="content-container" class="relative z-10 bg-[#0a0a0b] shadow-[0_-50px_100px_rgba(0,0,0,0.9)]">
            
            <section id="services-wrapper" class="pt-1 lg:pt-5">
                <Services />
            </section>

            

            <ProjectsSection />
            <section class="py-1 lg:py-5">
                <TechStack />
            </section>
            <section id="contact-section" class="py-20 lg:py-32">
                <ContactSection />
            </section>

            <Footer />
        </div>
    </main>
</Layout>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    
    gsap.registerPlugin(ScrollTrigger);

    const initGlobalAnimations = () => {
        // Matamos instancias previas para evitar duplicados en Astro
        ScrollTrigger.getAll().forEach(t => t.kill());

        // Animación suave de salida del Hero
        gsap.to("#hero-wrapper", {
            scrollTrigger: {
                trigger: "#content-container",
                start: "top bottom", 
                end: "top top",    
                scrub: true,       
            },
            scale: 0.9,
            opacity: 0,
            y: 100, // Efecto parallax sutil
            ease: "none"
        });

        // Refrescamos después de inicializar todo
        ScrollTrigger.refresh();
    };

    document.addEventListener('astro:page-load', () => {
        initGlobalAnimations();
    });
</script>

<style>
    :global(html) {
        scroll-behavior: auto !important; /* El scroll-behavior smooth rompe a veces a GSAP */
        background: #0a0a0b;
    }

    /* Limpiamos estilos que causan bugs en ScrollTrigger Pinning */
    main {
        overflow-x: hidden;
        position: relative;
    }

    #content-container {
        min-height: 100vh;
        position: relative;
        z-index: 10;
        /* Quitamos perspective: 1px ya que rompe el fixed de GSAP */
    }
</style>