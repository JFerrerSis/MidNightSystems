---
import { Github, Instagram, Send, Cpu, ExternalLink, Linkedin } from 'lucide-astro';

const añoActual = new Date().getFullYear();
const nombrePersonal = "Jorge Ferrer";

// Conexión con variables de entorno
const usuarioGithub = import.meta.env.PUBLIC_GITHUB_USER || "JferrerSis";
const usuarioInstagram = import.meta.env.PUBLIC_INSTAGRAM_USER;
---

<footer class="bg-[#050505] pt-24 pb-12 px-6 border-t border-white/5 relative overflow-hidden">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-cyan-500/5 blur-[120px] rounded-full pointer-events-none"></div>
    <div class="absolute bottom-0 right-0 w-64 h-64 bg-pink-500/5 blur-[100px] rounded-full pointer-events-none"></div>
    
    <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-8 mb-20">
            
            <div class="lg:col-span-5 space-y-8 flex flex-col items-center lg:items-start text-center lg:text-left">
                <div class="group cursor-pointer">
                    <div class="flex items-center gap-3 transition-transform duration-500 group-hover:-translate-y-1">
                        <div class="w-10 h-10 rounded-xl bg-linear-to-br from-white/10 to-white/5 border border-white/10 flex items-center justify-center shadow-2xl">
                            <Cpu size={22} class="text-cyan-400 animate-pulse" />
                        </div>
                        <span class="text-white font-black tracking-tighter text-2xl uppercase italic">
                            Midnight<span class="text-gray-500 font-light not-italic uppercase tracking-normal">Systems</span>
                        </span>
                    </div>
                </div>
                
                <p class="text-gray-400 text-sm font-light leading-relaxed max-w-sm">
                    Especialista en desarrollo web y soporte IT. Transformando ideas complejas en interfaces minimalistas y funcionales desde <span class="text-white">Venezuela</span> pal' mundo.
                </p>

                <div class="flex items-center gap-4">
                    <a href={`https://github.com/${usuarioGithub}`} target="_blank" class="p-3 rounded-full bg-white/5 border border-white/5 text-gray-400 hover:text-white hover:border-white/20 hover:scale-110 transition-all duration-300">
                        <Github size={20} />
                    </a>
                    {usuarioInstagram && (
                        <a href={`https://instagram.com/${usuarioInstagram}`} target="_blank" class="p-3 rounded-full bg-white/5 border border-white/5 text-gray-400 hover:text-pink-500 hover:border-pink-500/20 hover:scale-110 transition-all duration-300">
                            <Instagram size={20} />
                        </a>
                    )}
                </div>
            </div>

            <div class="lg:col-span-3 flex flex-col items-center lg:items-start space-y-6">
                <h4 class="text-white font-mono text-[10px] uppercase tracking-[0.4em] mb-2">Navegación</h4>
                <ul class="space-y-4 text-center lg:text-left">
                    <li><a href="#services-section" class="text-gray-500 hover:text-cyan-400 text-sm transition-colors flex items-center gap-2 group justify-center lg:justify-start">Servicios <ExternalLink size={12} class="opacity-0 group-hover:opacity-100 transition-opacity" /></a></li>
                    <li><a href="#projects-section" class="text-gray-500 hover:text-cyan-400 text-sm transition-colors flex items-center gap-2 group justify-center lg:justify-start">Proyectos <ExternalLink size={12} class="opacity-0 group-hover:opacity-100 transition-opacity" /></a></li>
                    <li><a href="#contact-section" class="text-gray-500 hover:text-cyan-400 text-sm transition-colors flex items-center gap-2 group justify-center lg:justify-start">Contacto <ExternalLink size={12} class="opacity-0 group-hover:opacity-100 transition-opacity" /></a></li>
                </ul>
            </div>

            <div class="lg:col-span-4 flex flex-col items-center lg:items-end space-y-8">
                <div class="w-full max-w-xs p-6 rounded-4xl bg-white/2 border border-white/5 backdrop-blur-sm group hover:border-cyan-500/20 transition-all">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="relative flex h-2 w-2">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
                        </div>
                        <span class="text-[10px] font-mono text-white uppercase tracking-widest">Status: Disponible</span>
                    </div>
                    <p class="text-[11px] text-gray-500 font-mono leading-tight">
                        Actualmente aceptando proyectos freelance de desarrollo web y consultoría técnica.
                    </p>
                </div>
            </div>
        </div>

        <div class="pt-10 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6">
            <div class="flex flex-col md:flex-row items-center gap-2 md:gap-6">
                <span class="text-gray-600 text-[9px] font-mono uppercase tracking-[0.4em]">
                    © {añoActual} — {nombrePersonal}
                </span>
                <span class="hidden md:block w-1 h-1 bg-white/10 rounded-full"></span>
                <span class="text-gray-700 text-[9px] font-mono uppercase tracking-[0.4em]">
                    Venezuela
                </span>
            </div>
            
            <div class="flex items-center gap-2 group">
                <div class="p-1.5 rounded-md bg-white/5 group-hover:bg-cyan-500/10 transition-colors">
                    <Send size={10} class="text-gray-600 group-hover:text-cyan-400 transition-colors" />
                </div>
                <span class="text-gray-600 group-hover:text-gray-300 text-[9px] font-mono uppercase tracking-[0.4em] transition-colors italic">
                    Pixel Perfect Development
                </span>
            </div>
        </div>
    </div>
</footer>

<style>
    footer {
        /* Asegura que el footer se sienta parte de la misma profundidad que el resto */
        box-shadow: 0 -20px 50px -20px rgba(0,0,0,0.5);
    }
</style>