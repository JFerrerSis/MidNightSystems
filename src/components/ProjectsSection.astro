---
// Mantener los imports y la lógica de fetch igual...
import { 
  Layers, ShieldCheck, Rocket, Atom, 
  Code2, Palette, Terminal, Cpu, FolderGit2, ExternalLink, Github
} from 'lucide-astro';

interface Project {
    name: string;
    description: string;
    stack: { name: string; color: string; icon: any }[];
    url: string;
    previewTitle: string;
    accentColor: string;
    image: string; 
}

const GITHUB_USERNAME = "JferrerSis";
const ALLOWED_REPOS = ['AmuletoCat', 'MidNightStudio', 'Invitacion15', 'Bcv-Scrap'];

const CUSTOM_URLS: Record<string, string> = {
    'AmuletoCat': 'https://amuletoahm-ar.vercel.app/',
    'MidNightStudio': 'https://studiomidnight.vercel.app/',
    'Invitacion15': 'https://sofiaparra.vercel.app/',
    'Bcv-Scrap': 'https://bcv-scrap.vercel.app/'
};

let projects: Project[] = [];

try {
    const response = await fetch(`https://api.github.com/users/${GITHUB_USERNAME}/repos?per_page=100`);
    const allRepos = await response.json();
    const filteredRepos = allRepos.filter((repo: any) => 
        ALLOWED_REPOS.map(n => n.toLowerCase()).includes(repo.name.toLowerCase())
    );

    const techConfig: Record<string, { color: string, icon: any }> = {
        JavaScript: { color: 'text-yellow-400 bg-yellow-400/10 border-yellow-400/20', icon: Layers },
        TypeScript: { color: 'text-blue-400 bg-blue-400/10 border-blue-400/20', icon: ShieldCheck },
        Astro: { color: 'text-orange-500 bg-orange-500/10 border-orange-500/20', icon: Rocket },
        React: { color: 'text-cyan-400 bg-cyan-400/10 border-cyan-400/20', icon: Atom },
        Default: { color: 'text-gray-400 bg-white/5 border-white/10', icon: Cpu }
    };

    projects = filteredRepos.map((repo: any) => {
        const mainLang = repo.language || 'Default';
        const config = techConfig[mainLang] || techConfig.Default;
        const customKey = Object.keys(CUSTOM_URLS).find(k => k.toLowerCase() === repo.name.toLowerCase());
        const finalUrl = customKey ? CUSTOM_URLS[customKey] : (repo.homepage || repo.html_url);

        return {
            name: repo.name.replace(/-/g, ' '),
            description: repo.description || "Solución digital optimizada con alto impacto visual.",
            stack: [{ name: mainLang, ...config }],
            url: finalUrl,
            previewTitle: finalUrl.replace(/^https?:\/\//, '').split('/')[0],
            accentColor: config.color.split(' ')[0].replace('text-', 'bg-'),
            image: `https://api.microlink.io/?url=${finalUrl}&screenshot=true&meta=false&embed=screenshot.url`
        };
    });
} catch (e) {
    console.error(e);
}
---

<section class="relative py-24 px-4 bg-[#0a0a0b] overflow-hidden" id="projects-section">
    <div class="absolute top-0 right-0 w-64 h-64 bg-cyan-500/5 blur-[100px] rounded-full pointer-events-none parallax-glow" data-speed="0.01"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-pink-500/5 blur-[100px] rounded-full pointer-events-none parallax-glow" data-speed="0.02"></div>

    <div class="max-w-5xl mx-auto relative z-10">
        
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-20 gap-6" id="projects-header-container">
            <div class="space-y-2" id="projects-header">
                <div class="flex items-center gap-2 overflow-hidden">
                    <span class="w-8 h-px bg-cyan-500 anim-reveal-line"></span>
                    <span class="text-cyan-500 font-mono text-[9px] uppercase tracking-[0.4em] anim-reveal-text">Showcase</span>
                </div>
                
                <div class="overflow-hidden py-1">
                    <h2 class="text-white text-3xl md:text-5xl font-black tracking-tighter uppercase italic anim-reveal-title leading-tight">
                        Proyectos <span class="text-stroke text-white/5">Lab</span>
                    </h2>
                </div>
            </div>
            
            <div class="anim-reveal-btn opacity-0">
                <a href={`https://github.com/${GITHUB_USERNAME}`} target="_blank" class="group flex items-center gap-3 bg-white/5 border border-white/10 px-6 py-3 rounded-xl hover:bg-cyan-500/10 hover:border-cyan-500/30 transition-all text-[9px] font-mono text-gray-400 hover:text-cyan-400 uppercase tracking-widest no-underline backdrop-blur-md">
                    <Github class="w-4 h-4 group-hover:rotate-12 transition-transform" />
                    <span>Open Source</span>
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 lg:gap-16" id="projects-grid">
            {projects.map((project, index) => (
                <article 
                    class="project-card group relative flex flex-col pointer-events-auto"
                    data-speed={index % 2 === 0 ? "0.03" : "0.06"}
                >
                    <div class="card-inner relative bg-[#111112] border border-white/5 rounded-4xl overflow-hidden transition-all duration-500 hover:border-cyan-500/20 shadow-xl">
                        
                        <div class="spotlight absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>

                        <div class="p-8 grow flex flex-col relative z-10">
                            <div class="flex justify-between items-start mb-6">
                                <div class="flex gap-2">
                                    {project.stack.map((tech) => (
                                        <div class={`flex items-center gap-1.5 px-3 py-1 rounded-lg border text-[8px] font-bold uppercase tracking-wider ${tech.color}`}>
                                            <tech.icon size={10} />
                                            {tech.name}
                                        </div>
                                    ))}
                                </div>
                                <FolderGit2 class="w-5 h-5 text-gray-700 group-hover:text-cyan-400 transition-colors" />
                            </div>

                            <h3 class="text-white text-xl font-bold mb-2 tracking-tight group-hover:text-cyan-300 transition-colors capitalize">
                                {project.name}
                            </h3>
                            <p class="text-gray-400 text-xs leading-relaxed mb-8 font-light italic line-clamp-2 opacity-80">
                                {project.description}
                            </p>

                            <div class="mt-auto">
                                <a href={project.url} target="_blank" class="group/btn relative inline-flex items-center gap-3 text-[9px] font-black text-white uppercase tracking-[0.2em] no-underline">
                                    <span class="relative z-10 opacity-70 group-hover/btn:opacity-100 transition-opacity">Launch App</span>
                                    <div class="p-2 bg-white/5 rounded-full group-hover/btn:bg-cyan-500 group-hover/btn:text-black transition-all duration-300">
                                        <ExternalLink class="w-3 h-3" />
                                    </div>
                                </a>
                            </div>
                        </div>

                        <div class="relative px-8 pb-8 mt-auto z-10 perspective-1000">
                            <div class="preview-container rounded-xl border border-white/10 bg-[#0a0a0b] overflow-hidden shadow-2xl transform-style-3d group-hover:rotate-x-2 group-hover:scale-[1.02] transition-all duration-700">
                                <div class="bg-white/5 px-3 py-2 flex items-center justify-between border-b border-white/5">
                                    <div class="flex gap-1.5">
                                        <div class="w-2 h-2 rounded-full bg-red-500/10"></div>
                                        <div class="w-2 h-2 rounded-full bg-yellow-500/10"></div>
                                        <div class="w-2 h-2 rounded-full bg-green-500/10"></div>
                                    </div>
                                    <span class="text-[7px] font-mono text-gray-600 uppercase tracking-widest">{project.previewTitle}</span>
                                </div>
                                <div class="relative aspect-video bg-[#0a0a0b] overflow-hidden">
                                    <img 
                                        src={project.image} 
                                        alt={project.name}
                                        class="w-full h-full object-cover object-top opacity-30 group-hover:opacity-100 transition-all duration-1000 grayscale group-hover:grayscale-0"
                                    />
                                    <div class={`absolute inset-0 mix-blend-overlay opacity-10 ${project.accentColor}`}></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </article>
            ))}
        </div>
    </div>
</section>

<style>
    .text-stroke {
        -webkit-text-stroke: 0.5px rgba(255, 255, 255, 0.15);
        color: transparent;
    }

    .perspective-1000 { perspective: 1000px; }
    .transform-style-3d { transform-style: preserve-3d; }

    #projects-section {
        contain: paint;
    }

    .card-inner {
        will-change: transform, border-color;
    }

    .anim-reveal-title {
        transform-origin: bottom;
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    function initProjects() {
        const cards = document.querySelectorAll(".project-card");
        const glows = document.querySelectorAll(".parallax-glow");

        // 1. Animación de Entrada del Header (REVELADO)
        const headerTl = gsap.timeline({
            scrollTrigger: {
                trigger: "#projects-header-container",
                start: "top 90%",
            }
        });

        headerTl
            .from(".anim-reveal-line", { width: 0, duration: 1, ease: "expo.out" })
            .from(".anim-reveal-text", { x: -20, opacity: 0, duration: 0.8 }, "-=0.6")
            .from(".anim-reveal-title", { 
                y: "100%", 
                opacity: 0, 
                rotateX: -10,
                duration: 1.2, 
                ease: "power4.out" 
            }, "-=0.7")
            .to(".anim-reveal-btn", { opacity: 1, duration: 1 }, "-=0.8");

        // 2. Parallaje de Luces
        window.addEventListener("mousemove", (e) => {
            const x = (e.clientX / window.innerWidth) - 0.5;
            const y = (e.clientY / window.innerHeight) - 0.5;
            glows.forEach((glow) => {
                const speed = (glow as HTMLElement).dataset.speed || "0.01";
                gsap.to(glow, {
                    x: x * 60 * parseFloat(speed),
                    y: y * 60 * parseFloat(speed),
                    duration: 2,
                    ease: "power2.out"
                });
            });
        });

        // 3. Animación de Tarjetas
        cards.forEach((card, index) => {
            gsap.from(card, {
                scrollTrigger: {
                    trigger: card,
                    start: "top 95%",
                    toggleActions: "play none none reverse"
                },
                y: 50,
                opacity: 0,
                duration: 1.5,
                ease: "expo.out"
            });

            const speed = (card as HTMLElement).dataset.speed || "0.05";
            gsap.to(card, {
                scrollTrigger: {
                    trigger: card,
                    start: "top bottom",
                    end: "bottom top",
                    scrub: true
                },
                y: (i, target) => -100 * parseFloat(speed),
                ease: "none"
            });

            const spotlight = card.querySelector('.spotlight') as HTMLElement;
            card.addEventListener('mousemove', (e: any) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                gsap.to(spotlight, {
                    background: `radial-gradient(400px circle at ${x}px ${y}px, rgba(34, 211, 238, 0.05), transparent 70%)`,
                    duration: 0.5
                });
            });
        });
    }

    document.addEventListener('astro:page-load', initProjects);
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
        initProjects();
    }
</script>