---
import { 
  Layers, ShieldCheck, Rocket, Atom, 
  FolderGit2, ExternalLink, Github, Cpu
} from 'lucide-astro';

interface Project {
    name: string;
    description: string;
    stack: { name: string; color: string; icon: any }[];
    url: string;
    previewTitle: string;
    accentColor: string;
    image: string; 
}

const GITHUB_USERNAME = "JferrerSis";
const ALLOWED_REPOS = ['AmuletoCat', 'MidNightStudio', 'Invitacion15', 'Bcv-Scrap'];

const CUSTOM_URLS: Record<string, string> = {
    'AmuletoCat': 'https://amuletoahm-ar.vercel.app/',
    'MidNightStudio': 'https://studiomidnight.vercel.app/',
    'Invitacion15': 'https://sofiaparra.vercel.app/',
    'Bcv-Scrap': 'https://bcv-scrap.vercel.app/'
};

let projects: Project[] = [];

try {
    const response = await fetch(`https://api.github.com/users/${GITHUB_USERNAME}/repos?per_page=100`);
    const allRepos = await response.json();
    const filteredRepos = allRepos.filter((repo: any) => 
        ALLOWED_REPOS.map(n => n.toLowerCase()).includes(repo.name.toLowerCase())
    );

    const techConfig: Record<string, { color: string, icon: any }> = {
        JavaScript: { color: 'text-yellow-400 bg-yellow-400/10 border-yellow-400/20', icon: Layers },
        TypeScript: { color: 'text-blue-400 bg-blue-400/10 border-blue-400/20', icon: ShieldCheck },
        Astro: { color: 'text-orange-500 bg-orange-500/10 border-orange-500/20', icon: Rocket },
        React: { color: 'text-cyan-400 bg-cyan-400/10 border-cyan-400/20', icon: Atom },
        Default: { color: 'text-gray-400 bg-white/5 border-white/10', icon: Cpu }
    };

    projects = filteredRepos.map((repo: any) => {
        const mainLang = repo.language || 'Default';
        const config = techConfig[mainLang] || techConfig.Default;
        const customKey = Object.keys(CUSTOM_URLS).find(k => k.toLowerCase() === repo.name.toLowerCase());
        const finalUrl = customKey ? CUSTOM_URLS[customKey] : (repo.homepage || repo.html_url);

        return {
            name: repo.name.replace(/-/g, ' '),
            description: repo.description || "Solución digital optimizada con alto impacto visual.",
            stack: [{ name: mainLang, ...config }],
            url: finalUrl,
            previewTitle: finalUrl.replace(/^https?:\/\//, '').split('/')[0],
            accentColor: config.color.split(' ')[0].replace('text-', 'bg-'),
            image: `https://api.microlink.io/?url=${finalUrl}&screenshot=true&meta=false&embed=screenshot.url`
        };
    });
} catch (e) {
    console.error(e);
}
---

<section class="relative py-32 px-4 bg-[#0a0a0b] overflow-hidden" id="projects-section">
    <div class="absolute top-0 right-0 w-96 h-96 bg-cyan-500/5 blur-[120px] rounded-full pointer-events-none anim-glow"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-purple-500/5 blur-[120px] rounded-full pointer-events-none anim-glow"></div>

    <div class="max-w-5xl mx-auto relative z-10">
        
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-24 gap-8" id="projects-header">
            <div class="space-y-4">
                <div class="flex items-center gap-3 overflow-hidden">
                    <span class="w-12 h-px bg-cyan-500 anim-line"></span>
                    <span class="text-cyan-500 font-mono text-[10px] uppercase tracking-[0.5em] anim-tag">Portfolio</span>
                </div>
                
                <div class="overflow-hidden">
                    <h2 class="text-white text-4xl md:text-6xl font-black tracking-tighter uppercase italic anim-title leading-tight">
                        Proyectos <span class="text-white/10">Lab</span>
                    </h2>
                </div>
            </div>
            
            <div class="anim-btn">
                <a href={`https://github.com/${GITHUB_USERNAME}`} target="_blank" class="group flex items-center gap-3 bg-white/5 border border-white/10 px-6 py-4 rounded-2xl hover:bg-cyan-500/10 hover:border-cyan-500/30 transition-all text-[10px] font-mono text-gray-400 hover:text-cyan-400 uppercase tracking-widest no-underline backdrop-blur-md">
                    <Github class="w-5 h-5 group-hover:rotate-12 transition-transform" />
                    <span>View Repository</span>
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20" id="projects-grid">
            {projects.map((project: Project) => (
                <article class="project-card group relative flex flex-col">
                    <div class="card-inner relative bg-[#111112] border border-white/5 rounded-[2.5rem] overflow-hidden flex flex-col h-full transition-all duration-500 hover:border-cyan-500/20 shadow-2xl">
                        
                        <div class="spotlight absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>

                        <div class="p-10 grow flex flex-col relative z-10">
                            <div class="flex justify-between items-start mb-8">
                                <div class="flex gap-2">
                                    {project.stack.map((tech) => (
                                        <div class={`flex items-center gap-1.5 px-3 py-1 rounded-lg border text-[8px] font-bold uppercase tracking-wider ${tech.color}`}>
                                            <tech.icon size={10} />
                                            {tech.name}
                                        </div>
                                    ))}
                                </div>
                                <FolderGit2 class="w-6 h-6 text-white/10 group-hover:text-cyan-500 transition-colors" />
                            </div>

                            <h3 class="text-white text-2xl font-bold mb-3 tracking-tight group-hover:text-cyan-300 transition-colors capitalize">
                                {project.name}
                            </h3>
                            <p class="text-gray-400 text-sm leading-relaxed mb-10 font-light italic line-clamp-2 opacity-80">
                                {project.description}
                            </p>

                            <div class="mt-auto">
                                <a href={project.url} target="_blank" class="group/btn relative inline-flex items-center gap-4 text-[10px] font-black text-white uppercase tracking-[0.2em] no-underline">
                                    <span class="opacity-60 group-hover/btn:opacity-100 transition-opacity">Explore System</span>
                                    <div class="p-2.5 bg-white/5 rounded-full group-hover/btn:bg-cyan-500 group-hover/btn:text-black transition-all duration-300">
                                        <ExternalLink class="w-4 h-4" />
                                    </div>
                                </a>
                            </div>
                        </div>

                        <div class="px-10 pb-10 mt-auto z-10">
                            <div class="rounded-2xl border border-white/5 bg-[#0a0a0b] overflow-hidden aspect-video shadow-inner group-hover:border-cyan-500/20 transition-all duration-500">
                                <img 
                                    src={project.image} 
                                    alt={project.name}
                                    class="w-full h-full object-cover opacity-30 group-hover:opacity-100 transition-all duration-1000 grayscale group-hover:grayscale-0"
                                />
                            </div>
                        </div>
                    </div>
                </article>
            ))}
        </div>
    </div>
</section>

<style>
    .text-stroke {
        -webkit-text-stroke: 1px rgba(255, 255, 255, 0.1);
        color: transparent;
    }
    .project-card { will-change: transform, opacity; }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    function initProjects() {
        const header = document.querySelector("#projects-header");
        const cards = document.querySelectorAll(".project-card");

        if (!header || cards.length === 0) return;

        // 1. FORZAMOS RECALCULO DE ALTURAS
        ScrollTrigger.refresh();

        // 2. ANIMACIÓN DEL HEADER (Título y botón)
        // Usamos gsap.fromTo para asegurar que GSAP controle el inicio y el fin
        gsap.fromTo([".anim-line", ".anim-tag", ".anim-title", ".anim-btn"], 
            { 
                y: 50, 
                opacity: 0 
            },
            {
                y: 0,
                opacity: 1,
                stagger: 0.1,
                ease: "none", // 'none' es mejor para scrub puro
                scrollTrigger: {
                    trigger: header,
                    start: "top 95%", // Empieza casi al final de la pantalla
                    end: "top 60%",   // Termina de aparecer cuando llega al 60%
                    scrub: 1,         // Suavizado de inercia
                }
            }
        );

        // 3. ANIMACIÓN DE LAS TARJETAS
        cards.forEach((card) => {
            gsap.fromTo(card, 
                { 
                    y: 120,          // Más desplazamiento para que se note el efecto
                    opacity: 0, 
                    scale: 0.85 
                },
                {
                    y: 0,
                    opacity: 1,
                    scale: 1,
                    ease: "power1.inOut",
                    scrollTrigger: {
                        trigger: card,
                        // El 'start' define cuando empieza a aparecer al BAJAR
                        start: "top 98%", 
                        // El 'end' define cuando termina de aparecer
                        // Ajustado a 'center center' para que el recorrido sea más largo y fluido
                        end: "top 65%",   
                        scrub: 1.2,       // Un poco más de inercia para elegancia
                    }
                }
            );

            // Lógica de Spotlight (Mouse move) se mantiene igual
            const spotlight = card.querySelector('.spotlight') as HTMLElement;
            card.addEventListener('mousemove', (e: any) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                gsap.to(spotlight, {
                    background: `radial-gradient(500px circle at ${x}px ${y}px, rgba(34, 211, 238, 0.12), transparent 80%)`,
                    duration: 0.4
                });
            });
        });
    }

    // Eventos de carga para Astro
    document.addEventListener('astro:page-load', initProjects);
    
    // Ejecución inmediata si el DOM ya está listo
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
        initProjects();
    }
</script>