---
import { 
  Layers, ShieldCheck, Rocket, Atom, 
  Code2, Palette, Terminal, Cpu, FolderGit2, ExternalLink
} from 'lucide-astro';

interface Project {
    name: string;
    description: string;
    stack: { name: string; color: string; icon: any }[];
    url: string;
    previewTitle: string;
    accentColor: string;
}

const GITHUB_USERNAME = "JferrerSis";
const ALLOWED_REPOS = ['AmuletoCat', 'MidNightStudio', 'Invitacion15', 'Bcv-Scrap'];

const CUSTOM_URLS: Record<string, string> = {
    'AmuletoCat': 'https://amuletoahm-ar.vercel.app/',
    'MidNightStudio': 'https://studiomidnight.vercel.app/',
    'Invitacion15': 'https://sofiaparra.vercel.app/',
    'Bcv-Scrap': 'https://bcv-scrap.vercel.app/'
};

let projects: Project[] = [];

try {
    const response = await fetch(`https://api.github.com/users/${GITHUB_USERNAME}/repos?per_page=100`);
    const allRepos = await response.json();

    const filteredRepos = allRepos.filter((repo: any) => 
        ALLOWED_REPOS.map(n => n.toLowerCase()).includes(repo.name.toLowerCase())
    );

    const techConfig: Record<string, { color: string, icon: any }> = {
        JavaScript: { color: 'text-yellow-400 bg-yellow-400/10 border-yellow-400/20 lg:text-gray-400 lg:group-hover:text-yellow-400', icon: Layers },
        TypeScript: { color: 'text-blue-400 bg-blue-400/10 border-blue-400/20 lg:text-gray-400 lg:group-hover:text-blue-400', icon: ShieldCheck },
        Astro: { color: 'text-orange-500 bg-orange-500/10 border-orange-500/20 lg:text-gray-400 lg:group-hover:text-orange-500', icon: Rocket },
        React: { color: 'text-cyan-400 bg-cyan-400/10 border-cyan-400/20 lg:text-gray-400 lg:group-hover:text-cyan-400', icon: Atom },
        HTML: { color: 'text-orange-600 bg-orange-600/10 border-orange-600/20 lg:text-gray-400 lg:group-hover:text-orange-600', icon: Code2 },
        CSS: { color: 'text-indigo-400 bg-indigo-400/10 border-indigo-400/20 lg:text-gray-400 lg:group-hover:text-indigo-400', icon: Palette },
        Default: { color: 'text-gray-400 bg-white/5 border-white/10', icon: Cpu }
    };

    projects = filteredRepos.map((repo: any) => {
        const mainLang = repo.language || 'Default';
        const config = techConfig[mainLang] || techConfig.Default;
        const customKey = Object.keys(CUSTOM_URLS).find(k => k.toLowerCase() === repo.name.toLowerCase());
        const finalUrl = customKey ? CUSTOM_URLS[customKey] : (repo.homepage || repo.html_url);

        return {
            name: repo.name.replace(/-/g, ' '),
            description: repo.description || "Solución digital optimizada con alto impacto visual.",
            stack: [{ name: mainLang, ...config }],
            url: finalUrl,
            previewTitle: finalUrl.replace(/^https?:\/\//, '').split('/')[0],
            accentColor: config.color.split(' ')[0].replace('text-', 'bg-')
        };
    });
} catch (e) {
    console.error(e);
}
---

<section class="relative py-24 px-4 sm:px-6 lg:px-8 bg-[#050505]" id="projects-section">
    <div class="max-w-7xl mx-auto">
        
        {/* Título de la sección con el estilo de Midnight */}
        <div class="mb-16 text-center sm:text-left">
            <span class="text-pink-500 font-mono text-xs uppercase tracking-[0.3em] mb-4 block">Portafolio</span>
            <h2 class="text-white text-4xl md:text-5xl font-black tracking-tighter">
                Proyectos <span class="text-gray-500 text-3xl md:text-4xl font-light">/ Seleccionados</span>
            </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {projects.length > 0 ? (
                projects.map((project: Project) => (
                    <article class="project-card group relative bg-white/2 border border-white/5 rounded-3xl overflow-hidden hover:border-cyan-500/30 transition-all duration-500 flex flex-col opacity-0 translate-y-12">
                        <div class="p-8 grow">
                            <div class="flex justify-between items-start mb-6">
                                <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center border border-white/10 group-hover:scale-110 transition-transform">
                                    <FolderGit2 class="w-5 h-5 text-gray-400 group-hover:text-cyan-400 transition-colors" />
                                </div>
                                <div class="flex gap-2">
                                    {project.stack.map((tech) => (
                                        <div class={`flex items-center gap-1.5 px-2.5 py-1 rounded-md border text-[10px] font-mono font-bold uppercase tracking-wider transition-colors duration-500 ${tech.color}`}>
                                            <tech.icon size={12} />
                                            {tech.name}
                                        </div>
                                    ))}
                                </div>
                            </div>

                            <h3 class="text-white text-2xl font-bold mb-3 tracking-tight group-hover:text-cyan-300 transition-colors capitalize">
                                {project.name}
                            </h3>
                            <p class="text-gray-400 text-sm leading-relaxed mb-6 line-clamp-3 font-light italic">
                                {project.description}
                            </p>
                            <a href={project.url} target="_blank" class="inline-flex items-center gap-2 text-[10px] font-black text-white uppercase tracking-[0.2em] group/btn hover:text-cyan-400 transition-colors">
                                Explorar <ExternalLink class="w-3 h-3 group-hover/btn:translate-x-1 transition-transform" />
                            </a>
                        </div>

                        <div class="relative px-6 pb-6 mt-auto">
                            <div class="browser-window rounded-t-xl border-t border-x border-white/10 bg-[#080808] overflow-hidden group-hover:-translate-y-2 transition-transform duration-500">
                                <div class="bg-white/5 px-3 py-2 flex items-center justify-between border-b border-white/5">
                                    <div class="flex gap-1">
                                        <div class="w-1.5 h-1.5 rounded-full bg-red-500/20"></div>
                                        <div class="w-1.5 h-1.5 rounded-full bg-yellow-500/20"></div>
                                        <div class="w-1.5 h-1.5 rounded-full bg-green-500/20"></div>
                                    </div>
                                    <span class="text-[8px] font-mono text-gray-600 uppercase tracking-widest">{project.previewTitle}</span>
                                </div>
                                <div class="p-4 h-28 bg-[#050505] relative overflow-hidden">
                                    <div class="space-y-2">
                                        <div class="h-1 w-full bg-white/5 rounded-full overflow-hidden">
                                            <div class="h-full bg-cyan-500/20 w-1/3 animate-pulse"></div>
                                        </div>
                                        <div class="h-1 w-4/5 bg-white/5 rounded-full"></div>
                                    </div>
                                    {/* El resplandor inferior también usa el color de acento del stack */}
                                    <div class={`absolute -bottom-4 -right-4 w-16 h-16 blur-2xl rounded-full opacity-20 ${project.accentColor}`}></div>
                                </div>
                            </div>
                        </div>
                    </article>
                ))
            ) : (
                <div class="col-span-full text-center py-20 border border-dashed border-white/10 rounded-3xl bg-white/1">
                    <p class="text-gray-500 font-mono text-xs uppercase tracking-widest animate-pulse">Sincronizando con Repositorios de Jorge Ferrer...</p>
                </div>
            )}
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    const initProjects = () => {
        const cards = document.querySelectorAll(".project-card");
        if (cards.length > 0) {
            gsap.to(cards, {
                opacity: 1,
                y: 0,
                duration: 1,
                stagger: 0.2,
                ease: "power4.out",
                scrollTrigger: {
                    trigger: "#projects-section",
                    start: "top 75%",
                    toggleActions: "play none none reverse"
                }
            });
        }
    };

    // Ejecución segura para Astro (con transiciones de página)
    document.addEventListener('DOMContentLoaded', initProjects);
    document.addEventListener('astro:page-load', initProjects);
</script>