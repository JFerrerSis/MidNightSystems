---
import { 
  Layers, ShieldCheck, Rocket, Atom, 
  Code2, Palette, Terminal, Cpu, FolderGit2, ExternalLink, Github
} from 'lucide-astro';

interface Project {
    name: string;
    description: string;
    stack: { name: string; color: string; icon: any }[];
    url: string;
    previewTitle: string;
    accentColor: string;
    image: string; 
}

const GITHUB_USERNAME = "JferrerSis";
const ALLOWED_REPOS = ['AmuletoCat', 'MidNightStudio', 'Invitacion15', 'Bcv-Scrap'];

const CUSTOM_URLS: Record<string, string> = {
    'AmuletoCat': 'https://amuletoahm-ar.vercel.app/',
    'MidNightStudio': 'https://studiomidnight.vercel.app/',
    'Invitacion15': 'https://sofiaparra.vercel.app/',
    'Bcv-Scrap': 'https://bcv-scrap.vercel.app/'
};

let projects: Project[] = [];

try {
    const response = await fetch(`https://api.github.com/users/${GITHUB_USERNAME}/repos?per_page=100`);
    const allRepos = await response.json();

    const filteredRepos = allRepos.filter((repo: any) => 
        ALLOWED_REPOS.map(n => n.toLowerCase()).includes(repo.name.toLowerCase())
    );

    const techConfig: Record<string, { color: string, icon: any }> = {
        JavaScript: { color: 'text-yellow-400 bg-yellow-400/10 border-yellow-400/20', icon: Layers },
        TypeScript: { color: 'text-blue-400 bg-blue-400/10 border-blue-400/20', icon: ShieldCheck },
        Astro: { color: 'text-orange-500 bg-orange-500/10 border-orange-500/20', icon: Rocket },
        React: { color: 'text-cyan-400 bg-cyan-400/10 border-cyan-400/20', icon: Atom },
        Default: { color: 'text-gray-400 bg-white/5 border-white/10', icon: Cpu }
    };

    projects = filteredRepos.map((repo: any) => {
        const mainLang = repo.language || 'Default';
        const config = techConfig[mainLang] || techConfig.Default;
        const customKey = Object.keys(CUSTOM_URLS).find(k => k.toLowerCase() === repo.name.toLowerCase());
        const finalUrl = customKey ? CUSTOM_URLS[customKey] : (repo.homepage || repo.html_url);

        return {
            name: repo.name.replace(/-/g, ' '),
            description: repo.description || "Solución digital optimizada con alto impacto visual.",
            stack: [{ name: mainLang, ...config }],
            url: finalUrl,
            previewTitle: finalUrl.replace(/^https?:\/\//, '').split('/')[0],
            accentColor: config.color.split(' ')[0].replace('text-', 'bg-'),
            image: `https://api.microlink.io/?url=${finalUrl}&screenshot=true&meta=false&embed=screenshot.url`
        };
    });
} catch (e) {
    console.error(e);
}
---

<section class="relative py-24 px-4 bg-[#050505] overflow-hidden" id="projects-section">
    <div class="absolute top-0 left-1/4 w-72 h-72 bg-cyan-500/5 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-0 right-1/4 w-72 h-72 bg-pink-500/5 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="max-w-6xl mx-auto relative z-10">
        
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6 overflow-hidden">
            <div class="space-y-3" id="projects-header">
                <div class="flex items-center gap-3 anim-header">
                    <span class="w-8 h-px bg-pink-500"></span>
                    <span class="text-pink-500 font-mono text-[10px] uppercase tracking-[0.4em]">Portfolio</span>
                </div>
                <h2 class="text-white text-4xl md:text-5xl font-black tracking-tighter uppercase italic anim-header">
                    Proyectos 
                </h2>
            </div>
            <a href={`https://github.com/${GITHUB_USERNAME}`} target="_blank" class="anim-header group flex items-center gap-3 bg-white/5 border border-white/10 px-5 py-2.5 rounded-full hover:bg-white/10 transition-all text-[10px] font-mono text-gray-400 hover:text-white uppercase tracking-widest">
                <Github class="w-4 h-4" />
                Explorar GitHub
            </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {projects.map((project) => (
                <article class="project-card group relative bg-white/1 border border-white/5 rounded-4xl overflow-hidden hover:border-white/10 transition-all duration-500 flex flex-col">
                    
                    <div class="spotlight absolute inset-0 bg-radial from-cyan-500/5 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

                    <div class="p-8 md:p-10 grow flex flex-col">
                        <div class="flex justify-between items-start mb-8">
                            <div class="flex gap-2">
                                {project.stack.map((tech) => (
                                    <div class={`flex items-center gap-1.5 px-3 py-1 rounded-full border text-[9px] font-bold uppercase tracking-wider ${tech.color}`}>
                                        <tech.icon size={10} />
                                        {tech.name}
                                    </div>
                                ))}
                            </div>
                            <FolderGit2 class="w-5 h-5 text-gray-700 group-hover:text-cyan-400 transition-colors" />
                        </div>

                        <h3 class="text-white text-2xl font-bold mb-3 tracking-tight group-hover:text-cyan-300 transition-colors capitalize">
                            {project.name}
                        </h3>
                        <p class="text-gray-500 text-sm leading-relaxed mb-6 font-light italic line-clamp-2">
                            {project.description}
                        </p>

                        <div class="mt-auto">
                            <a href={project.url} target="_blank" class="group/btn inline-flex items-center gap-3 text-[10px] font-black text-white uppercase tracking-[0.2em] hover:text-cyan-400 transition-colors">
                                Explorar Proyecto
                                <ExternalLink class="w-3.h-3 group-hover/btn:translate-x-1 group-hover/btn:-translate-y-1 transition-transform" />
                            </a>
                        </div>
                    </div>

                    <div class="relative px-6 pb-6 mt-auto">
                        <div class="preview-window rounded-xl border border-white/10 bg-[#080808] overflow-hidden shadow-2xl group-hover:-translate-y-2 transition-transform duration-500">
                            <div class="bg-white/5 px-3 py-2 flex items-center justify-between border-b border-white/5">
                                <div class="flex gap-1">
                                    <div class="w-1.5 h-1.5 rounded-full bg-white/10"></div>
                                    <div class="w-1.5 h-1.5 rounded-full bg-white/10"></div>
                                </div>
                                <span class="text-[8px] font-mono text-gray-600 uppercase tracking-widest">{project.previewTitle}</span>
                            </div>
                            <div class="relative aspect-video bg-[#050505] overflow-hidden">
                                <img 
                                    src={project.image} 
                                    alt={project.name}
                                    class="w-full h-full object-cover object-top opacity-40 group-hover:opacity-100 transition-all duration-700 group-hover:scale-105"
                                />
                                <div class={`absolute inset-0 mix-blend-color opacity-20 ${project.accentColor}`}></div>
                            </div>
                        </div>
                    </div>
                </article>
            ))}
        </div>
    </div>
</section>

<style>
    .stroke-text {
        -webkit-text-stroke: 1px rgba(255, 255, 255, 0.15);
    }
    .project-card {
        will-change: transform, opacity;
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    function initProjects() {
        const cards = document.querySelectorAll(".project-card");
        const headerAnims = document.querySelectorAll(".anim-header");

        // 1. Animación Header
        gsap.from(headerAnims, {
            y: 30,
            opacity: 0,
            duration: 0.8,
            stagger: 0.1,
            ease: "power3.out",
            scrollTrigger: {
                trigger: "#projects-header",
                start: "top 90%",
                toggleActions: "play reverse play reverse"
            }
        });
        
        // 2. Animación de las tarjetas (Pop & Fade reversible)
        cards.forEach((card, index) => {
            gsap.fromTo(card, 
                { opacity: 0, y: 60, scale: 0.95 },
                { 
                    opacity: 1, 
                    y: 0, 
                    scale: 1,
                    duration: 1, 
                    ease: "expo.out",
                    scrollTrigger: {
                        trigger: card,
                        start: "top 85%",
                        end: "bottom 15%",
                        toggleActions: "play reverse play reverse"
                    }
                }
            );
        });

        // 3. Spotlight sutil
        cards.forEach(card => {
            const spotlight = card.querySelector('.spotlight') as HTMLElement;
            card.addEventListener('mousemove', (e: any) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                gsap.to(spotlight, {
                    background: `radial-gradient(400px circle at ${x}px ${y}px, rgba(6, 182, 212, 0.08), transparent 40%)`,
                    duration: 0.3
                });
            });
        });
    }

    document.addEventListener('astro:page-load', initProjects);
    initProjects();
</script>