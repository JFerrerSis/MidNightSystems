---
import { 
  Layers, ShieldCheck, Rocket, Atom, 
  ExternalLink, Github, Cpu
} from 'lucide-astro';

interface Project {
    name: string;
    description: string;
    stack: { name: string; color: string; icon: any }[];
    url: string;
    image: string; 
}

const GITHUB_USERNAME = "JferrerSis";
const ALLOWED_REPOS = ['AmuletoCat', 'MidNightStudio', 'Invitacion15', 'Bcv-Scrap'];

const CUSTOM_URLS: Record<string, string> = {
    'AmuletoCat': 'https://amuletoahm-ar.vercel.app/',
    'MidNightStudio': 'https://studiomidnight.vercel.app/',
    'Invitacion15': 'https://sofiaparra.vercel.app/',
    'Bcv-Scrap': 'https://bcv-scrap.vercel.app/'
};

let projects: Project[] = [];

try {
    const response = await fetch(`https://api.github.com/users/${GITHUB_USERNAME}/repos?per_page=100`);
    const allRepos = await response.json();
    const filteredRepos = allRepos.filter((repo: any) => 
        ALLOWED_REPOS.map(n => n.toLowerCase()).includes(repo.name.toLowerCase())
    );

    const techConfig: Record<string, { color: string, icon: any }> = {
        JavaScript: { color: 'text-yellow-400 bg-yellow-400/10 border-yellow-400/20', icon: Layers },
        TypeScript: { color: 'text-blue-400 bg-blue-400/10 border-blue-400/20', icon: ShieldCheck },
        Astro: { color: 'text-orange-500 bg-orange-500/10 border-orange-500/20', icon: Rocket },
        React: { color: 'text-cyan-400 bg-cyan-400/10 border-cyan-400/20', icon: Atom },
        Default: { color: 'text-gray-400 bg-white/5 border-white/10', icon: Cpu }
    };

    projects = filteredRepos.map((repo: any) => {
        const mainLang = repo.language || 'Default';
        const config = techConfig[mainLang] || techConfig.Default;
        const customKey = Object.keys(CUSTOM_URLS).find(k => k.toLowerCase() === repo.name.toLowerCase());
        const finalUrl = customKey ? CUSTOM_URLS[customKey] : (repo.homepage || repo.html_url);

        return {
            name: repo.name.replace(/-/g, ' '),
            description: repo.description || "Solución digital optimizada con alto impacto visual.",
            stack: [{ name: mainLang, ...config }],
            url: finalUrl,
            image: `https://api.microlink.io/?url=${finalUrl}&screenshot=true&meta=false&embed=screenshot.url`
        };
    });
} catch (e) { console.error(e); }
---

<section id="horizontal-section" class="relative bg-transparent w-full overflow-hidden">
    <div class="absolute top-0 right-[-10%] w-125 h-125 bg-cyan-500/5 blur-[120px] rounded-full pointer-events-none floating-glow"></div>
    <div class="absolute bottom-0 left-[-10%] w-125 h-125 bg-purple-500/5 blur-[120px] rounded-full pointer-events-none floating-glow"></div>

    <div id="pin-container" class="h-screen w-full flex flex-col justify-center relative overflow-hidden">
        
        <div class="max-w-7xl mx-auto w-full px-6 mb-16 relative z-20" id="projects-header">
            <div class="flex items-center gap-4 mb-4 anim-reveal">
                <span class="h-px bg-cyan-500 w-12 block"></span>
                <span class="text-cyan-500 font-mono text-[10px] uppercase tracking-[0.5em]">Selected Works</span>
            </div>
            <h2 class="text-white text-5xl md:text-8xl font-black tracking-tight uppercase italic leading-none anim-reveal">
                PROYECTOS <span class="text-outline-thin opacity-20">LAB.</span>
            </h2>
        </div>

        <div id="project-rail" class="flex flex-nowrap items-center gap-12 px-[10vw] md:px-[15vw] will-change-transform">
            {projects.map((project, index) => (
                <article class="project-card shrink-0 w-[85vw] md:w-[60vw] lg:w-[45vw]">
                    <div class="card-inner relative bg-[#0d0d0f]/80 border border-white/10 rounded-[2.5rem] overflow-hidden group backdrop-blur-3xl">
                        <div class="spotlight absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

                        <div class="p-8 md:p-12 grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
                            <div class="space-y-6 relative z-10">
                                <div class="flex gap-2">
                                    {project.stack.map(tech => (
                                        <div class={`flex items-center gap-2 px-3 py-1 rounded-full border text-[8px] font-bold uppercase tracking-widest ${tech.color}`}>
                                            <tech.icon size={10} />
                                            {tech.name}
                                        </div>
                                    ))}
                                </div>
                                <h3 class="text-white text-2xl md:text-4xl font-black italic uppercase leading-none tracking-tighter">
                                    {project.name}
                                </h3>
                                <p class="text-gray-500 text-xs md:text-sm font-light italic leading-relaxed">
                                    {project.description}
                                </p>
                                <a href={project.url} target="_blank" class="inline-flex items-center gap-4 group/btn no-underline">
                                    <div class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center group-hover/btn:bg-white group-hover/btn:text-black transition-all">
                                        <ExternalLink size={14} />
                                    </div>
                                    <span class="text-[9px] font-black text-white/40 uppercase tracking-widest">Launch Experience</span>
                                </a>
                            </div>

                            <div class="rounded-2xl overflow-hidden aspect-video bg-black border border-white/5 relative">
                                <img 
                                    src={project.image} 
                                    alt={project.name}
                                    class="project-img w-full h-full object-cover opacity-40 grayscale group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700"
                                />
                                <div class="absolute inset-0 bg-linear-to-t from-[#0d0d0f] to-transparent opacity-60"></div>
                            </div>
                        </div>
                    </div>
                </article>
            ))}

           
        </div>
    </div>
</section>

<style>
    .text-outline-thin {
        -webkit-text-stroke: 1px rgba(255, 255, 255, 0.4);
        color: transparent;
    }
    
    .floating-glow {
        animation: float 15s ease-in-out infinite;
    }

    @keyframes float {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(30px, -50px) scale(1.1); }
    }

    #horizontal-section {
        /* Bloqueamos el renderizado lateral para que no rompa el layout global */
        contain: paint;
    }
    
    #project-rail {
        display: flex;
        flex-wrap: nowrap;
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    function initHorizontalScroll() {
        const section = document.querySelector("#horizontal-section");
        const rail = document.querySelector("#project-rail");
        const pinContainer = document.querySelector("#pin-container");

        if (!section || !rail || !pinContainer) return;

        // 1. LIMPIEZA TOTAL (Para evitar el bug de "desaparece todo")
        ScrollTrigger.getAll().forEach(st => st.kill());

        // 2. CÁLCULO DE DESPLAZAMIENTO
        // Queremos mover el rail hacia la izquierda todo su ancho menos lo que ya vemos en pantalla
        const getScrollAmount = () => -(rail.scrollWidth - window.innerWidth);

        // 3. ANIMACIÓN PRINCIPAL
        gsap.to(rail, {
            x: getScrollAmount,
            ease: "none",
            scrollTrigger: {
                trigger: section,
                start: "top top", // Se activa cuando la sección llega al techo
                end: () => `+=${rail.scrollWidth}`, // La duración depende de cuántos proyectos haya
                pin: true, // Bloquea el scroll vertical
                pinSpacing: true, // ¡CRUCIAL! Crea el espacio necesario para que las secciones de abajo no se monten
                scrub: 1, // Movimiento suave atado al scroll
                invalidateOnRefresh: true, // Recalcula si cambias el tamaño de ventana
                anticipatePin: 1,
            }
        });

        // Spotlight
        const cards = document.querySelectorAll(".project-card");
        cards.forEach((card) => {
            const spotlight = card.querySelector('.spotlight') as HTMLElement;
            card.addEventListener('mousemove', (e: any) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                gsap.to(spotlight, {
                    background: `radial-gradient(600px circle at ${x}px ${y}px, rgba(34, 211, 238, 0.15), transparent 80%)`,
                    duration: 0.3
                });
            });
        });

        // Refrescamos al final para asegurar que GSAP lea bien el DOM
        ScrollTrigger.refresh();
    }

    document.addEventListener('astro:page-load', initHorizontalScroll);
    initHorizontalScroll();

    // Recalcular en resize para que no se rompa el final
    window.addEventListener('resize', () => {
        ScrollTrigger.refresh();
    });
</script>