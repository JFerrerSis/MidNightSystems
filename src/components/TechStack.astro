---
import { 
  Cpu, Code2, Globe, Database, Terminal, Layers, 
  Settings, Zap, Monitor, ShieldCheck, Wrench, HardDrive,
  Server
} from 'lucide-astro';

const groups = [
  {
    category: "Desarrollo Frontend",
    items: [
      { name: "Astro", icon: Code2, color: "text-orange-500" },
      { name: "React", icon: Cpu, color: "text-blue-400" },
      { name: "Tailwind", icon: Layers, color: "text-cyan-400" },
      { name: "GSAP", icon: Globe, color: "text-green-400" },
    ]
  },
  {
    category: "Backend & Core",
    items: [
      { name: "Bun", icon: Zap, color: "text-orange-200" },
      { name: "Next.js", icon: Globe, color: "text-white" },
      { name: "SQL Server", icon: Database, color: "text-red-500" },
      { name: "PostgreSQL", icon: Server, color: "text-blue-300" },
    ]
  },
  {
    category: "Soporte IT & Hardware",
    items: [
      { name: "Mantenimiento", icon: Wrench, color: "text-red-400" },
      { name: "Sistemas OS", icon: Monitor, color: "text-blue-500" },
      { name: "Diagnóstico", icon: ShieldCheck, color: "text-emerald-500" },
      { name: "Hardware", icon: HardDrive, color: "text-purple-400" },
    ]
  }
];
---

<section class="py-24 px-4 bg-[#050505] relative overflow-hidden" id="tech-section">
  <div class="absolute top-0 left-1/4 w-72 h-72 bg-cyan-500/5 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-0 right-1/4 w-72 h-72 bg-purple-500/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-w-6xl mx-auto relative z-10">
    
    <div class="mb-20 overflow-hidden" id="tech-header">
      <div class="flex items-center gap-3 mb-4 anim-header-tech">
        <span class="w-8 h-px bg-pink-500"></span>
        <span class="text-pink-500 font-mono text-[10px] uppercase tracking-[0.4em]">Habilidades</span>
      </div>
      <h2 class="text-white text-4xl md:text-5xl font-black tracking-tighter uppercase italic anim-header-tech">
        Tech <span class="text-transparent stroke-text not-italic">Stack.</span>
      </h2>
    </div>

    <div class="space-y-24">
      {groups.map((group) => (
        <div class="tech-group">
          <h3 class="text-gray-500 font-mono text-[10px] uppercase tracking-[0.4em] mb-12 flex items-center gap-4">
            <span class="h-px grow bg-linear-to-r from-transparent via-white/10 to-transparent line-l"></span>
            <span class="px-4 opacity-0 translate-y-4 category-title">{group.category}</span>
            <span class="h-px grow bg-linear-to-r from-transparent via-white/10 to-transparent line-r"></span>
          </h3>
          
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 perspective-1000">
            {group.items.map((item) => (
              <div class="tech-card group relative p-6 rounded-2xl border border-white/5 bg-white/2 hover:bg-white/4 transition-colors duration-500 hover:border-white/20 overflow-hidden">
                <div class="absolute inset-0 bg-linear-to-br from-white/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                <div class="flex flex-col items-center gap-4 relative z-10">
                  <div class={`p-3 rounded-xl bg-white/5 border border-white/10 group-hover:scale-110 group-hover:rotate-6 transition-all duration-500 shadow-xl ${item.color}`}>
                    <item.icon size={28} strokeWidth={1.5} />
                  </div>
                  <span class="text-gray-400 group-hover:text-white text-sm font-semibold tracking-wide transition-colors">
                    {item.name}
                  </span>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stroke-text {
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.15);
  }
  .tech-card {
    transform-style: preserve-3d;
    will-change: transform, opacity, filter;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  function init() {
    gsap.registerPlugin(ScrollTrigger);

    // 1. Animación de Cabecera (Unificada)
    const headerAnims = document.querySelectorAll(".anim-header-tech");
    gsap.from(headerAnims, {
      y: 30,
      opacity: 0,
      duration: 0.8,
      stagger: 0.1,
      ease: "power3.out",
      scrollTrigger: {
        trigger: "#tech-header",
        start: "top 90%",
        toggleActions: "play reverse play reverse"
      }
    });

    // 2. Animación Grupos y Tarjetas (Pop desde el centro)
    const groups = document.querySelectorAll(".tech-group");
    groups.forEach((group) => {
      const cards = group.querySelectorAll(".tech-card");
      const title = group.querySelector(".category-title");
      
      gsap.to(title, {
        opacity: 1,
        y: 0,
        duration: 0.8,
        scrollTrigger: {
          trigger: group,
          start: "top 90%",
          end: "bottom 10%",
          toggleActions: "play reverse play reverse"
        }
      });

      gsap.fromTo(cards, 
        { scale: 0, opacity: 0, filter: "blur(10px)", y: 40 },
        {
          scale: 1, opacity: 1, filter: "blur(0px)", y: 0,
          stagger: { each: 0.1, from: "center" },
          duration: 0.8,
          ease: "back.out(1.5)",
          scrollTrigger: {
            trigger: group,
            start: "top 85%",
            end: "bottom 15%",
            toggleActions: "play reverse play reverse"
          }
        }
      );
    });

    // 3. Efecto Tilt
    document.querySelectorAll('.tech-card').forEach(card => {
      card.addEventListener('mousemove', (e) => {
        const ev = e as MouseEvent;
        const rect = (card as HTMLElement).getBoundingClientRect();
        const x = ev.clientX - rect.left - rect.width / 2;
        const y = ev.clientY - rect.top - rect.height / 2;
        gsap.to(card, {
          rotateY: x * 0.15,
          rotateX: -y * 0.15,
          scale: 1.02,
          duration: 0.4,
          ease: "power2.out"
        });
      });
      card.addEventListener('mouseleave', () => {
        gsap.to(card, { rotateX: 0, rotateY: 0, scale: 1, duration: 0.6 });
      });
    });
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>