---
import { Database, Monitor, Cpu, ShieldCheck } from "lucide-astro";

const groups = [
  {
    category: "Desarrollo Frontend",
    items: [
      { name: "Astro", logo: "https://cdn.simpleicons.org/astro/white", glow: "#ff5d01", isLucide: false },
      { name: "React", logo: "https://cdn.simpleicons.org/react/61DAFB", glow: "#61DAFB", isLucide: false },
      { name: "Tailwind", logo: "https://cdn.simpleicons.org/tailwindcss/06B6D4", glow: "#06B6D4", isLucide: false },
      { name: "TypeScript", logo: "https://cdn.simpleicons.org/typescript", glow: "#4169E1", isLucide: false },
    ],
  },
  {
    category: "Backend & Core",
    items: [
      { name: "Next.js", logo: "https://cdn.simpleicons.org/nextdotjs/white", glow: "#ffffff", isLucide: false },
      { name: "Node.js", logo: "https://cdn.simpleicons.org/nodedotjs/339933", glow: "#339933", isLucide: false },
      { name: "SQL Server", logo: Database, glow: "#CC2927", isLucide: true, color: "text-[#CC2927]" },
      { name: "PostgreSQL", logo: "https://cdn.simpleicons.org/postgresql/4169E1", glow: "#4169E1", isLucide: false },
    ],
  },
  {
    category: "Soporte IT & Sistemas",
    items: [
      { name: "Windows Server", logo: Monitor, glow: "#0078D4", isLucide: true, color: "text-[#0078D4]" },
      { name: "Linux/Ubuntu", logo: "https://cdn.simpleicons.org/ubuntu/E95420", glow: "#E95420", isLucide: false },
      { name: "Redes & Seg.", logo: ShieldCheck, glow: "#10b981", isLucide: true, color: "text-[#10b981]" },
      { name: "Hardware/Mantenim.", logo: Cpu, glow: "#f59e0b", isLucide: true, color: "text-[#f59e0b]" },
    ],
  },
];
---

<section class="py-24 px-4 bg-[#050505] relative overflow-hidden" id="tech-section">
  <div class="absolute top-0 left-1/4 w-72 h-72 bg-cyan-500/5 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-0 right-1/4 w-72 h-72 bg-purple-500/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-w-6xl mx-auto relative z-10">
    <div class="mb-20 overflow-hidden" id="tech-header">
      <div class="flex items-center gap-3 mb-4 anim-header-tech opacity-0">
        <span class="w-8 h-px bg-pink-500"></span>
        <span class="text-pink-500 font-mono text-[10px] uppercase tracking-[0.4em]">Habilidades</span>
      </div>
      <h2 class="text-white text-4xl md:text-5xl font-black tracking-tighter uppercase italic anim-header-tech opacity-0">
        Tech <span class="text-transparent stroke-text not-italic">Stack.</span>
      </h2>
    </div>

    <div class="space-y-24">
      {groups.map((group) => (
        <div class="tech-group">
          <h3 class="text-gray-500 font-mono text-[10px] uppercase tracking-[0.4em] mb-12 flex items-center gap-4">
            <span class="h-px grow bg-linear-to-r from-transparent via-white/10 to-transparent"></span>
            <span class="px-4 opacity-0 translate-y-4 category-title italic">{group.category}</span>
            <span class="h-px grow bg-linear-to-r from-transparent via-white/10 to-transparent"></span>
          </h3>

          <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 perspective-1000">
            {group.items.map((item) => (
              <div 
                class="tech-card opacity-0 translate-y-10 group relative p-6 rounded-2xl border border-white/10 bg-white/2 overflow-hidden transition-all duration-500"
                style={`--glow-color: ${item.glow}`}
              >
                <div class="flex flex-col items-center gap-4 relative z-10">
                    <div class="p-3 rounded-xl bg-white/5 border border-white/10 icon-container">
                        {item.isLucide ? (
                            <item.logo class={`w-8 h-8 ${item.color || ''}`} strokeWidth={1.5} />
                        ) : (
                            <img src={item.logo as string} alt={item.name} class="w-8 h-8 object-contain" />
                        )}
                    </div>
                    <span class="text-white text-[10px] font-mono text-center uppercase tracking-widest">{item.name}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stroke-text { -webkit-text-stroke: 1px rgba(255, 255, 255, 0.15); }
  .tech-card { transform-style: preserve-3d; will-change: transform, opacity; }
  
  @media (min-width: 641px) {
    .tech-card:hover {
      border-color: var(--glow-color);
      box-shadow: 0 0 20px -5px var(--glow-color);
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  function initTechStack() {
    gsap.registerPlugin(ScrollTrigger);

    // Matamos triggers previos de esta sección
    ScrollTrigger.getAll().forEach(st => {
      if (st.trigger && (st.trigger as HTMLElement).closest('#tech-section')) st.kill();
    });

    // 1. Animación Header
    gsap.to(".anim-header-tech", {
      y: 0,
      opacity: 1,
      duration: 0.8,
      stagger: 0.1,
      ease: "power3.out",
      scrollTrigger: {
        trigger: "#tech-header",
        start: "top 90%",
        once: true
      }
    });

    // 2. Animación por Grupos
    const techGroups = document.querySelectorAll(".tech-group");
    techGroups.forEach((group) => {
      const cards = group.querySelectorAll(".tech-card");
      const title = group.querySelector(".category-title");

      // Título de categoría
      gsap.to(title, {
        opacity: 1, 
        y: 0, 
        duration: 0.6,
        scrollTrigger: {
          trigger: group,
          start: "top 85%",
          once: true
        }
      });

      // Cards
      gsap.to(cards, {
        opacity: 1,
        y: 0,
        stagger: 0.05,
        duration: 0.8,
        ease: "back.out(1.4)",
        scrollTrigger: {
          trigger: group,
          start: "top 80%",
          once: true
        }
      });
    });

    // 3. REFRESH CONTROLADO: Vital para que ProjectsSection no rompa esto
    setTimeout(() => {
        ScrollTrigger.refresh();
    }, 200);
  }

  // Soporte para Astro View Transitions
  document.addEventListener("astro:page-load", initTechStack);
  
  // Ejecución inicial
  initTechStack();
</script>