---
import { Cpu, Code2, Globe, Database, Terminal, Layers, Settings } from 'lucide-astro';

const technologies = [
  { name: "Astro", icon: Code2, color: "text-orange-500" },
  { name: "Tailwind CSS", icon: Layers, color: "text-cyan-400" },
  { name: "React", icon: Cpu, color: "text-blue-400" },
  { name: "TypeScript", icon: Terminal, color: "text-blue-600" },
  { name: "JavaScript", icon: Code2, color: "text-yellow-400" },
  { name: "SQL", icon: Database, color: "text-emerald-400" },
  { name: "GSAP", icon: Globe, color: "text-green-400" },
  { name: "PostCSS", icon: Settings, color: "text-orange-400" },
];
---

<section class="py-20 bg-[#050505] overflow-hidden border-y border-white/5">
  <div class="max-w-7xl mx-auto px-4 mb-10 text-center">
    <h2 class="text-gray-500 font-mono text-[10px] uppercase tracking-[0.5em]">Tecnologías & Herramientas</h2>
  </div>

  <div class="relative flex overflow-x-hidden group/marquee">
    <div class="flex animate-marquee whitespace-nowrap items-center gap-12 sm:gap-20 py-4">
      {
        [...technologies, ...technologies].map((tech) => (
          <div class="flex items-center gap-3 group">
            {/* Color fijo en mobile, gris en desktop (lg), color en hover (lg:group-hover) */}
            <tech.icon class={`w-6 h-6 ${tech.color} lg:text-gray-600 lg:group-hover:${tech.color} transition-colors duration-300`} />
            <span class={`font-mono text-sm tracking-tighter text-white lg:text-gray-600 lg:group-hover:text-white transition-colors duration-300`}>
              {tech.name}
            </span>
          </div>
        ))
      }
    </div>

    <div class="absolute top-0 flex animate-marquee2 whitespace-nowrap items-center gap-12 sm:gap-20 py-4">
      {
        [...technologies, ...technologies].map((tech) => (
          <div class="flex items-center gap-3 group">
            <tech.icon class={`w-6 h-6 ${tech.color} lg:text-gray-600 lg:group-hover:${tech.color} transition-colors duration-300`} />
            <span class={`font-mono text-sm tracking-tighter text-white lg:text-gray-600 lg:group-hover:text-white transition-colors duration-300`}>
              {tech.name}
            </span>
          </div>
        ))
      }
    </div>

    <div class="absolute inset-y-0 left-0 w-32 bg-linear-to-r from-[#050505] to-transparent z-10"></div>
    <div class="absolute inset-y-0 right-0 w-32 bg-linear-to-l from-[#050505] to-transparent z-10"></div>
  </div>
</section>

<style>
  .animate-marquee {
    animation: marquee 40s linear infinite;
  }

  .animate-marquee2 {
    animation: marquee2 40s linear infinite;
  }

  @keyframes marquee {
    0% { transform: translateX(0%); }
    100% { transform: translateX(-100%); }
  }

  @keyframes marquee2 {
    0% { transform: translateX(100%); }
    100% { transform: translateX(0%); }
  }

  /* Pausar solo en desktop para no interrumpir el scroll en móvil */
  @media (min-width: 1024px) {
    .group\/marquee:hover .animate-marquee,
    .group\/marquee:hover .animate-marquee2 {
      animation-play-state: paused;
    }
  }
</style>