---
import {
  MessageCircle,
  Instagram,
  Send,
  User,
  AtSign,
  MessageSquare,
  ShieldCheck,
} from "lucide-astro";

const FORM_ACTION = "https://formspree.io/f/mjgpdjlp";
---

<section
  class="py-24 px-4 relative overflow-hidden"
  id="contact-section"
>
  <div class="absolute top-0 right-0 w-80 h-80 bg-cyan-500/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-w-6xl mx-auto relative z-10">
    <div class="mb-16 overflow-hidden" id="contact-header">
      <div class="flex items-center gap-3 mb-4 anim-contact-up">
        <span class="w-8 h-px bg-pink-500"></span>
        <span class="text-pink-500 font-mono text-[10px] uppercase tracking-[0.4em]">Contáctame</span>
      </div>
      <h2 class="text-white text-4xl md:text-5xl font-black tracking-tighter uppercase italic anim-contact-up">
        ¿Tienes un <span class="text-transparent stroke-text not-italic">Proyecto?</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <div class="contact-form-container relative opacity-0 translate-x-12 min-h-125">
        <form id="contact-form" action={FORM_ACTION} method="POST" class="space-y-6 transition-all duration-500">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="space-y-2 group">
              <label class="text-[10px] font-mono text-gray-500 uppercase tracking-widest ml-4 group-focus-within:text-cyan-400">Nombre</label>
              <div class="relative">
                <User class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-600 group-focus-within:text-cyan-500 transition-colors" size={18} />
                <input type="text" name="name" required placeholder="Tu nombre" class="w-full bg-white/5 border border-white/5 rounded-2xl py-4 pl-12 pr-4 text-white placeholder:text-gray-700 focus:border-cyan-500/50 focus:bg-white/10 transition-all outline-none" />
              </div>
            </div>
            <div class="space-y-2 group">
              <label class="text-[10px] font-mono text-gray-500 uppercase tracking-widest ml-4 group-focus-within:text-cyan-400">Email</label>
              <div class="relative">
                <AtSign class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-600 group-focus-within:text-cyan-500 transition-colors" size={18} />
                <input type="email" name="email" required placeholder="tu@email.com" class="w-full bg-white/5 border border-white/5 rounded-2xl py-4 pl-12 pr-4 text-white placeholder:text-gray-700 focus:border-cyan-500/50 focus:bg-white/10 transition-all outline-none" />
              </div>
            </div>
          </div>

          <div class="space-y-2 group">
            <label class="text-[10px] font-mono text-gray-500 uppercase tracking-widest ml-4 group-focus-within:text-cyan-400">Mensaje</label>
            <div class="relative">
              <MessageSquare class="absolute left-4 top-6 text-gray-600 group-focus-within:text-cyan-500 transition-colors" size={18} />
              <textarea name="message" required rows="4" placeholder="Cuéntame sobre tu idea..." class="w-full bg-white/5 border border-white/5 rounded-3xl py-4 pl-12 pr-4 text-white placeholder:text-gray-700 focus:border-cyan-500/50 focus:bg-white/10 transition-all outline-none resize-none"></textarea>
            </div>
          </div>

          <div class="flex items-start gap-4 px-2 anim-terms group/terms">
            <div class="relative flex items-center h-5 mt-1">
              <input id="terms" type="checkbox" required class="peer h-5 w-5 rounded-lg border-white/10 bg-white/5 text-cyan-500 focus:ring-cyan-500/20 transition-all cursor-pointer appearance-none border checked:bg-cyan-500" />
              <ShieldCheck class="absolute pointer-events-none opacity-0 peer-checked:opacity-100 text-black left-1 top-1" size={12} strokeWidth={3} />
            </div>
            <div class="flex flex-col gap-1">
              <label for="terms" class="text-[11px] text-gray-400 leading-tight cursor-pointer select-none group-hover/terms:text-gray-300 transition-colors">
                Acepto los <span class="text-cyan-500/80 font-medium">Términos de Privacidad</span>
              </label>
              <p class="text-[9px] text-gray-600 font-mono uppercase tracking-wider leading-relaxed max-w-sm">
                Autorizas a <span class="text-gray-500">Midnight Systems</span> a procesar tus datos para gestionar esta consulta técnica. No compartimos tu información.
              </p>
            </div>
          </div>

          <button type="submit" id="submit-btn" disabled class="w-full bg-white text-black font-black py-4 rounded-2xl uppercase tracking-[0.3em] text-xs hover:bg-cyan-500 hover:text-white disabled:opacity-30 disabled:grayscale disabled:cursor-not-allowed transition-all duration-500 flex items-center justify-center gap-3 group/btn">
            <span id="btn-text">Enviar Mensaje</span>
            <Send size={16} class="group-hover/btn:translate-x-1 group-hover/btn:-translate-y-1 transition-transform" />
          </button>
        </form>

        <div id="form-status" class="absolute inset-0 flex flex-col items-center justify-center text-center p-6 bg-[#050505]/95 backdrop-blur-xl border border-white/10 rounded-[2.5rem] opacity-0 pointer-events-none transition-all duration-500 scale-95 z-50">
          <div id="status-icon-container" class="mb-4 p-5 rounded-full bg-white/5 border border-white/10 flex items-center justify-center">
            </div>
          <h3 id="status-title" class="text-xl sm:text-2xl font-bold text-white mb-2 tracking-tight"></h3>
          <p id="status-desc" class="text-[11px] sm:text-sm text-gray-500 italic font-light max-w-60 sm:max-w-xs leading-relaxed"></p>
        </div>
      </div>

      <div class="space-y-8 contact-info-container opacity-0 -translate-x-12">
        <p class="text-gray-400 text-lg italic font-light leading-relaxed">
          Si prefieres algo más directo, también puedes encontrarme en mis redes sociales. <span class="text-white">Respondemos en menos de 24 horas.</span>
        </p>

        <div class="grid grid-cols-1 gap-4">
          <a href="#" class="group flex items-center justify-between p-6 bg-white/5 border border-white/5 rounded-2xl hover:border-emerald-500/30 transition-all">
            <div class="flex items-center gap-4">
              <div class="p-3 bg-emerald-500/10 rounded-xl text-emerald-500 group-hover:scale-110 transition-transform"><MessageCircle size={24} /></div>
              <div>
                <h4 class="text-white font-bold tracking-tight">WhatsApp</h4>
                <p class="text-gray-500 text-xs font-mono uppercase">Respuesta inmediata</p>
              </div>
            </div>
            <span class="text-gray-700 group-hover:text-emerald-500 transition-colors">→</span>
          </a>

          <a href="#" class="group flex items-center justify-between p-6 bg-white/5 border border-white/5 rounded-2xl hover:border-pink-500/30 transition-all">
            <div class="flex items-center gap-4">
              <div class="p-3 bg-pink-500/10 rounded-xl text-pink-500 group-hover:scale-110 transition-transform"><Instagram size={24} /></div>
              <div>
                <h4 class="text-white font-bold tracking-tight">Instagram</h4>
                <p class="text-gray-500 text-xs font-mono uppercase">Mensaje directo</p>
              </div>
            </div>
            <span class="text-gray-700 group-hover:text-pink-500 transition-colors">→</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .stroke-text { -webkit-text-stroke: 1px rgba(255, 255, 255, 0.15); }
  .contact-form-container, .contact-info-container { will-change: transform, opacity; }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  function initContact() {
    // Animaciones GSAP
    gsap.from(".anim-contact-up", {
      y: 30, opacity: 0, stagger: 0.1, duration: 0.8,
      scrollTrigger: { trigger: "#contact-header", start: "top 95%", toggleActions: "play none none reverse" }
    });

    gsap.to(".contact-form-container", {
      opacity: 1, x: 0, duration: 1, ease: "power4.out",
      scrollTrigger: { trigger: ".contact-form-container", start: "top 90%", toggleActions: "play none none reverse" }
    });

    gsap.to(".contact-info-container", {
      opacity: 1, x: 0, duration: 1, ease: "power4.out",
      scrollTrigger: { trigger: ".contact-info-container", start: "top 90%", toggleActions: "play none none reverse" }
    });

    const form = document.getElementById("contact-form") as HTMLFormElement;
    const termsCheckbox = document.getElementById("terms") as HTMLInputElement;
    const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
    const btnText = document.getElementById("btn-text");
    const statusDiv = document.getElementById("form-status");
    const iconContainer = document.getElementById("status-icon-container");

    termsCheckbox?.addEventListener("change", () => {
      submitBtn.disabled = !termsCheckbox.checked;
    });

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (btnText) btnText.innerText = "Enviando...";
      submitBtn.disabled = true;

      try {
        const response = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          headers: { Accept: "application/json" },
        });
        showStatus(response.ok);
        if (response.ok) form.reset();
      } catch {
        showStatus(false);
      }
    });

    function showStatus(isSuccess: boolean) {
      const statusTitle = document.getElementById("status-title");
      const statusDesc = document.getElementById("status-desc");

      if (isSuccess) {
        if (iconContainer) iconContainer.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="sm:w-10 sm:h-10"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
        if (statusTitle) statusTitle.innerText = "¡Mensaje Recibido!";
        if (statusDesc) statusDesc.innerText = "Gracias por contactar. Jorge Ferrer te escribirá en menos de 24 horas.";
      } else {
        if (iconContainer) iconContainer.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="sm:w-10 sm:h-10"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>`;
        if (statusTitle) statusTitle.innerText = "Error al enviar";
        if (statusDesc) statusDesc.innerText = "Hubo un problema. Por favor intenta de nuevo o escríbenos por Instagram.";
      }

      gsap.to(form, { opacity: 0, scale: 0.95, duration: 0.4 });
      gsap.to(statusDiv, { opacity: 1, scale: 1, pointerEvents: "all", duration: 0.5, ease: "back.out(1.7)" });

      setTimeout(() => {
        gsap.to(statusDiv, { opacity: 0, scale: 0.95, duration: 0.4, pointerEvents: "none" });
        gsap.to(form, { opacity: 1, scale: 1, duration: 0.4, onComplete: () => {
          if (btnText) btnText.innerText = "Enviar Mensaje";
          submitBtn.disabled = true;
          if (termsCheckbox) termsCheckbox.checked = false;
        }});
      }, 4000);
    }
  }

  document.addEventListener("astro:page-load", initContact);
  initContact();
</script>