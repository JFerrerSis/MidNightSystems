---
import { Zap } from "lucide-astro";

interface Props {
  companyName: string;
  logoPath?: string;
}

const { companyName, logoPath = "/logodark.png" } = Astro.props;
const personalName = "Jorge Ferrer";
---

<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=Unbounded:wght@900&family=Inter:wght@300;400;600&display=swap");

  .font-display {
    font-family: "Unbounded", sans-serif;
  }
  .font-body {
    font-family: "Inter", sans-serif;
  }

  .text-stroke {
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.3);
    color: transparent;
    transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .group:hover .text-stroke {
    -webkit-text-stroke: 1px rgba(34, 211, 238, 0.8);
    filter: drop-shadow(0 0 15px rgba(34, 211, 238, 0.4));
  }

  body {
    -webkit-font-smoothing: antialiased;
    background-color: #020202;
    margin: 0;
    overflow-x: hidden;
  }

  @keyframes scroll-line-anim {
    0% {
      transform: translateY(-100%);
    }
    100% {
      transform: translateY(100%);
    }
  }
  .animate-scroll-line {
    animation: scroll-line-anim 2s cubic-bezier(0.7, 0, 0.3, 1) infinite;
  }
</style>

<header
  class="relative min-h-svh w-full flex items-center justify-center overflow-hidden bg-[#020202] px-6 py-20 font-body perspective-2000"
  id="hero-container"
>
  <div class="absolute inset-0 pointer-events-none z-10 parallax-bg">
    <div
      class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-cyan-500/10 blur-[120px] rounded-full"
    >
    </div>
    <div
      class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-pink-600/10 blur-[150px] rounded-full"
    >
    </div>
  </div>

  <div
    class="relative z-20 grid grid-cols-1 lg:grid-cols-12 gap-16 max-w-7xl w-full items-center"
    id="hero-main-content"
  >
    <div
      class="lg:col-span-7 flex flex-col items-center lg:items-start text-center lg:text-left"
    >
      <div
        id="hero-badge"
        class="opacity-0 mb-8 inline-flex items-center gap-3 px-4 py-2 border border-white/10 bg-white/5 backdrop-blur-md rounded-full"
      >
        <Zap class="text-cyan-400 animate-pulse" size={14} />
        <span
          class="text-white/90 text-[10px] sm:text-xs uppercase tracking-[0.4em] font-semibold"
        >
          {personalName}
          <span class="text-pink-500 mx-1">/</span> Architect & IT Support
        </span>
      </div>

      <h1
        class="font-display text-white uppercase mb-8 perspective-1000 group select-none overflow-hidden"
      >
        <span
          class="block text-5xl sm:text-7xl md:text-8xl lg:text-9xl leading-[0.85] tracking-tighter anim-title-reveal"
          id="title-line-1"
        >
          Midnight
        </span>
        <span
          class="block text-6xl sm:text-8xl md:text-9xl lg:text-[11rem] leading-[0.85] tracking-tighter text-stroke anim-title-reveal"
          id="title-line-2"
        >
          Systems
        </span>
      </h1>

      <div
        class="flex flex-col sm:flex-row items-center lg:items-start gap-8 opacity-0"
        id="hero-actions"
      >
        <p
          class="text-gray-400 text-base sm:text-lg lg:text-xl max-w-md font-light leading-relaxed"
        >
          Diseñamos infraestructuras digitales y experiencias de <span
            class="text-white font-medium">alto rendimiento</span
          > con estética brutalista.
        </p>
        <div class="w-px h-12 bg-white/20 hidden sm:block"></div>
        <a
          href="#contact-section"
          id="btn-contact"
          class="group/btn relative inline-flex items-center justify-center px-10 py-4 bg-white overflow-hidden rounded-xl no-underline"
        >
          <span
            class="relative z-10 text-black font-black text-sm uppercase tracking-widest"
            >Contáctame</span
          >
          <div
            class="absolute inset-0 bg-cyan-400 translate-y-full group-hover/btn:translate-y-0 transition-transform duration-300"
          >
          </div>
        </a>
      </div>
    </div>

    <div
      class="lg:col-span-5 flex justify-center lg:justify-end opacity-0"
      id="hero-graphic"
    >
      <div
        class="relative w-64 h-64 sm:w-80 sm:h-80 lg:w-96 lg:h-96"
        id="interactive-cube-container"
      >
        <div class="cube-wrapper w-full h-full">
          <div class="cube">
            <div class="face front"></div><div class="face back"></div>
            <div class="face right"></div><div class="face left"></div>
            <div class="face top"></div><div class="face bottom"></div>
            <div
              class="absolute inset-0 flex items-center justify-center transform-style-3d"
            >
              <img
                src={logoPath}
                alt="Logo"
                class="h-20 sm:h-28 w-auto z-30 filter drop-shadow(0 0 20px rgba(255,255,255,0.2))"
                style="transform: translateZ(20px);"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 z-30 opacity-0"
    id="scroll-hint"
  >
    <div class="flex flex-col items-center gap-4 cursor-pointer group">
      <div class="relative h-4 overflow-hidden">
        <span
          class="block text-[10px] uppercase tracking-[0.6em] text-white/30 group-hover:-translate-y-full transition-transform duration-500 ease-expo"
          >Desliza</span
        >
        <span
          class="absolute top-0 left-0 block text-[10px] uppercase tracking-[0.6em] text-cyan-400 translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-expo"
          >Desliza</span
        >
      </div>
      <div
        class="w-px h-14 bg-linear-to-b from-cyan-400/50 to-transparent relative overflow-hidden"
      >
        <div
          class="absolute top-0 left-0 w-full h-full bg-cyan-400 animate-scroll-line"
        >
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { ScrollToPlugin } from "gsap/ScrollToPlugin";

  // Registramos el plugin para el scroll suave
  gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);

  function initHero() {
    const container = document.querySelector("#hero-container");
    const contactBtn = document.querySelector("#btn-contact");
    if (!container) return;

    // --- 1. LÓGICA DE SCROLL SUAVE ---
    contactBtn?.addEventListener("click", (e) => {
      e.preventDefault();
      const targetId = contactBtn.getAttribute("href");
      if (!targetId) return;

      gsap.to(window, {
        duration: 1.5,
        scrollTo: { y: targetId, autoKill: true },
        ease: "power4.inOut",
      });
    });

    // Limpieza de triggers previos para evitar duplicados en Astro
    ScrollTrigger.getAll().forEach((t) => t.kill());

    // --- 2. ANIMACIÓN DE ENTRADA (Aparece al cargar) ---
    const entryTl = gsap.timeline({ defaults: { ease: "power4.out" } });

    gsap.set(".anim-title-reveal", { y: 140, skewY: 7, opacity: 0 });
    gsap.set("#hero-badge", { y: 20, opacity: 0, scale: 0.9 });
    gsap.set(["#hero-actions", "#hero-graphic", "#scroll-hint"], {
      y: 40,
      opacity: 0,
    });

    entryTl
      .to("#hero-badge", { opacity: 1, y: 0, scale: 1, duration: 1.2 })
      .to(
        ".anim-title-reveal",
        { opacity: 1, y: 0, skewY: 0, duration: 1.6, stagger: 0.15 },
        "-=0.8",
      )
      .to(
        ["#hero-actions", "#hero-graphic", "#scroll-hint"],
        { opacity: 1, y: 0, stagger: 0.2, duration: 1.2 },
        "-=1",
      );

    // --- 3. ANIMACIÓN DE SCROLL (Efecto parallax al bajar) ---
    const scrollTl = gsap.timeline({
      scrollTrigger: {
        trigger: container,
        start: "top top",
        end: "bottom 10%",
        scrub: 1,
        invalidateOnRefresh: true,
      },
    });

    scrollTl
      .to("#title-line-1", { x: -150, opacity: 0, filter: "blur(15px)", scale: 0.8 }, 0)
      .to("#title-line-2", { x: 150, opacity: 0, filter: "blur(15px)", scale: 0.8 }, 0)
      .to("#hero-graphic", { y: -100, opacity: 0, scale: 0.7, rotate: 10, filter: "blur(10px)" }, 0)
      .to("#hero-actions", { y: 50, opacity: 0, filter: "blur(10px)" }, 0)
      .to("#hero-badge", { y: -30, opacity: 0, scale: 0.8 }, 0)
      .to("#scroll-hint", { opacity: 0, y: 20 }, 0)
      .to(".parallax-bg", { opacity: 0 }, 0);

    // --- 4. PARALLAX MOUSE (Interacción del cubo y fondo) ---
    const handleMouseMove = (e: MouseEvent) => {
      const { clientX, clientY } = e;
      const xPos = clientX / window.innerWidth - 0.5;
      const yPos = clientY / window.innerHeight - 0.5;

      gsap.to(".parallax-bg", {
        x: xPos * 40,
        y: yPos * 40,
        duration: 2,
        ease: "power2.out",
      });
      gsap.to(".cube", {
        rotateY: xPos * 80,
        rotateX: -yPos * 80,
        duration: 1.5,
        ease: "power1.out",
      });
    };

    window.addEventListener("mousemove", handleMouseMove);
  }

  // Soporte para Astro y carga inicial
  document.addEventListener("astro:page-load", initHero);
  if (document.readyState !== "loading") initHero();
</script>

<style>
  #hero-container {
    contain: paint;
  }
  #interactive-cube-container {
    perspective: 1500px;
    transform-style: preserve-3d;
  }
  .cube-wrapper {
    transform-style: preserve-3d;
    filter: drop-shadow(0 0 50px rgba(34, 211, 238, 0.15));
  }
  .cube {
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
    will-change: transform;
    animation: autoSpin 30s infinite linear;
  }
  .face {
    position: absolute;
    width: 100%;
    height: 100%;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
  }
  .transform-style-3d {
    transform-style: preserve-3d;
  }

  /* Caras del cubo */
  .front {
    transform: translateZ(128px);
  }
  .back {
    transform: rotateY(180deg) translateZ(128px);
  }
  .right {
    transform: rotateY(90deg) translateZ(128px);
    border-color: rgba(34, 211, 238, 0.3);
  }
  .left {
    transform: rotateY(-90deg) translateZ(128px);
    border-color: rgba(219, 39, 119, 0.3);
  }
  .top {
    transform: rotateX(90deg) translateZ(128px);
  }
  .bottom {
    transform: rotateX(-90deg) translateZ(128px);
  }

  @media (min-width: 640px) {
    .front,
    .back,
    .right,
    .left,
    .top,
    .bottom {
      transform: translateZ(160px);
    }
    .back {
      transform: rotateY(180deg) translateZ(160px);
    }
    .right {
      transform: rotateY(90deg) translateZ(160px);
    }
    .left {
      transform: rotateY(-90deg) translateZ(160px);
    }
    .top {
      transform: rotateX(90deg) translateZ(160px);
    }
    .bottom {
      transform: rotateX(-90deg) translateZ(160px);
    }
  }

  @media (min-width: 1024px) {
    .front,
    .back,
    .right,
    .left,
    .top,
    .bottom {
      transform: translateZ(192px);
    }
    .back {
      transform: rotateY(180deg) translateZ(192px);
    }
    .right {
      transform: rotateY(90deg) translateZ(192px);
    }
    .left {
      transform: rotateY(-90deg) translateZ(192px);
    }
    .top {
      transform: rotateX(90deg) translateZ(192px);
    }
    .bottom {
      transform: rotateX(-90deg) translateZ(192px);
    }
  }

  @keyframes autoSpin {
    0% {
      transform: rotateY(0deg) rotateX(0deg);
    }
    100% {
      transform: rotateY(360deg) rotateX(360deg);
    }
  }
  .ease-expo {
    transition-timing-function: cubic-bezier(0.85, 0, 0.15, 1);
  }
</style>
