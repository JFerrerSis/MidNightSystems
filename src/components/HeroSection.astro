---
import { ArrowDown, Zap } from 'lucide-astro';

interface Props {
  companyName: string;
  logoPath?: string;
}

const { companyName, logoPath = "/logodark.png" } = Astro.props;
const personalName = "Jorge Ferrer";
---

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Unbounded:wght@900&family=Inter:wght@300;400;600&display=swap');
  
  .font-display { font-family: 'Unbounded', sans-serif; }
  .font-body { font-family: 'Inter', sans-serif; }

  .text-stroke {
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.3);
    color: transparent;
    transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
  }
  
  .group:hover .text-stroke {
    -webkit-text-stroke: 1px rgba(34, 211, 238, 0.8);
    filter: drop-shadow(0 0 15px rgba(34, 211, 238, 0.4));
  }

  body {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    background-color: #020202;
    margin: 0;
  }
</style>

<header
  class="relative min-h-svh w-full flex items-center justify-center overflow-hidden bg-[#020202] px-6 py-20 font-body perspective-2000"
  id="hero-container"
>
  <div class="absolute inset-0 pointer-events-none z-10 parallax-layer">
    <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-cyan-500/10 blur-[120px] rounded-full"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-pink-600/10 blur-[150px] rounded-full"></div>
  </div>

  <div class="relative z-20 grid grid-cols-1 lg:grid-cols-12 gap-16 max-w-7xl w-full items-center" id="hero-main-content">
    
    <div class="lg:col-span-7 flex flex-col items-center lg:items-start text-center lg:text-left parallax-item" data-speed="0.04">
      
      <div id="hero-badge" class="opacity-0 mb-8 inline-flex items-center gap-3 px-4 py-2 border border-white/10 bg-white/5 backdrop-blur-md rounded-full">
        <Zap class="text-cyan-400 animate-pulse" size={14} />
        <span class="text-white/90 text-[10px] sm:text-xs uppercase tracking-[0.4em] font-semibold">
          {personalName} <span class="text-pink-500 mx-1">/</span> Architect & IT Support
        </span>
      </div>

      <h1 class="font-display text-white uppercase mb-8 perspective-1000 group select-none">
        <span class="block text-5xl sm:text-7xl md:text-8xl lg:text-9xl leading-[0.85] tracking-tighter anim-title-reveal" id="title-line-1">
          Midnight
        </span>
        <span class="block text-6xl sm:text-8xl md:text-9xl lg:text-[11rem] leading-[0.85] tracking-tighter text-stroke anim-title-reveal" id="title-line-2">
          Systems
        </span>
      </h1>

      <div class="flex flex-col sm:flex-row items-center lg:items-start gap-8 opacity-0 anim-fade-in" id="hero-actions">
        <p class="text-gray-400 text-base sm:text-lg lg:text-xl max-w-md font-light leading-relaxed">
          Diseñamos infraestructuras digitales y experiencias de <span class="text-white font-medium">alto rendimiento</span> con estética brutalista.
        </p>
        <div class="w-px h-12 bg-white/20 hidden sm:block"></div>
        
        <a 
          href="#contact-section" 
          class="group/btn relative inline-flex items-center justify-center px-10 py-4 bg-white overflow-hidden rounded-xl transition-all duration-300 hover:scale-105 active:scale-95 shadow-2xl shadow-white/5 no-underline"
        >
          <span class="relative z-10 text-black font-black text-sm uppercase tracking-widest transition-colors duration-300">
            Contáctame
          </span>
          <div class="absolute inset-0 bg-cyan-400 translate-y-full group-hover/btn:translate-y-0 transition-transform duration-300"></div>
        </a>
      </div>
    </div>

    <div class="lg:col-span-5 flex justify-center lg:justify-end opacity-0 anim-fade-in parallax-item" id="hero-graphic" data-speed="0.07">
      <div class="relative w-64 h-64 sm:w-80 sm:h-80 lg:w-100 lg:h-100" id="interactive-cube-container">
        <div class="cube-wrapper w-full h-full">
          <div class="cube">
            <div class="face front"></div>
            <div class="face back"></div>
            <div class="face right"></div>
            <div class="face left"></div>
            <div class="face top"></div>
            <div class="face bottom"></div>
            
            <div class="absolute inset-0 flex items-center justify-center transform-style-3d">
              <img 
                src={logoPath} 
                alt="Logo" 
                class="h-20 sm:h-28 w-auto z-30 filter drop-shadow(0 0 20px rgba(255,255,255,0.2))"
                style="transform: translateZ(20px);"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-30 opacity-0 anim-fade-in" id="scroll-hint">
    <div class="flex flex-col items-center gap-2 cursor-pointer group">
      <span class="text-[9px] uppercase tracking-[0.6em] text-white/30 group-hover:text-cyan-400 transition-colors">Explore</span>
      <div class="w-5 h-8 border border-white/20 rounded-full flex justify-center p-1">
        <div class="w-1 h-1 bg-cyan-400 rounded-full animate-bounce"></div>
      </div>
    </div>
  </div>
</header>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initHero() {
    const container = document.querySelector("#hero-container");
    if (!container) return;

    const entryTl = gsap.timeline({ defaults: { ease: "expo.out" } });

    gsap.set(["#hero-badge", ".anim-title-reveal", "#hero-actions", "#hero-graphic", "#scroll-hint"], { 
      opacity: 0,
      y: 60
    });

    entryTl
      .to("#hero-badge", { opacity: 1, y: 0, duration: 1.2 })
      .to(".anim-title-reveal", { 
        opacity: 1, 
        y: 0, 
        duration: 1.4,
        stagger: 0.1,
        startAt: { scale: 1, skewY: 0 } // Título recto desde el inicio
      }, "-=1")
      .to(["#hero-actions", "#hero-graphic", "#scroll-hint"], { 
        opacity: 1, 
        y: 0, 
        stagger: 0.2, 
        duration: 1.2 
      }, "-=0.8");

    const handleMouseMove = (e: MouseEvent) => {
      const xPos = (e.clientX / window.innerWidth) - 0.5;
      const yPos = (e.clientY / window.innerHeight) - 0.5;

      gsap.to(".parallax-layer", {
        x: xPos * 30,
        y: yPos * 30,
        duration: 1.5,
      });

      document.querySelectorAll(".parallax-item").forEach((item) => {
        const speed = parseFloat((item as HTMLElement).dataset.speed || "0.05");
        gsap.to(item, {
          x: xPos * (window.innerWidth * speed),
          y: yPos * (window.innerHeight * speed),
          duration: 2,
          ease: "power2.out"
        });
      });

      gsap.to(".cube", {
        rotateY: xPos * 100,
        rotateX: -yPos * 100,
        duration: 1.5,
        ease: "power3.out"
      });
    };

    window.addEventListener("mousemove", handleMouseMove);

    gsap.to("#hero-main-content", {
      scrollTrigger: {
        trigger: "#hero-container",
        start: "top top",
        end: "bottom top",
        scrub: true,
      },
      y: -100,
      scale: 0.9,
      opacity: 0,
    });
  }

  document.addEventListener('astro:page-load', initHero);
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    initHero();
  }
</script>

<style>
  #hero-container {
    contain: paint;
    /* Eliminamos cualquier sombra o borde inferior */
    border-bottom: none;
    box-shadow: none;
  }

  #interactive-cube-container {
    perspective: 1500px;
    transform-style: preserve-3d;
  }

  .cube-wrapper {
    transform-style: preserve-3d;
    filter: drop-shadow(0 0 30px rgba(34, 211, 238, 0.15));
  }

  .cube {
    width: 100%;
    height: 100%;
    position: relative;
    transform-style: preserve-3d;
    will-change: transform;
    animation: autoSpin 20s infinite linear;
  }

  .face {
    position: absolute;
    width: 100%;
    height: 100%;
    background: rgba(255, 255, 255, 0.03);
    border: 1.5px solid rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(8px);
  }

  .transform-style-3d { transform-style: preserve-3d; }

  .front  { transform: translateZ(128px); }
  .back   { transform: rotateY(180deg) translateZ(128px); }
  .right  { transform: rotateY(90deg) translateZ(128px); border-color: rgba(34, 211, 238, 0.4); }
  .left   { transform: rotateY(-90deg) translateZ(128px); border-color: rgba(219, 39, 119, 0.4); }
  .top    { transform: rotateX(90deg) translateZ(128px); }
  .bottom { transform: rotateX(-90deg) translateZ(128px); }

  @media (min-width: 640px) {
    .front  { transform: translateZ(160px); }
    .back   { transform: rotateY(180deg) translateZ(160px); }
    .right  { transform: rotateY(90deg) translateZ(160px); }
    .left   { transform: rotateY(-90deg) translateZ(160px); }
    .top    { transform: rotateX(90deg) translateZ(160px); }
    .bottom { transform: rotateX(-90deg) translateZ(160px); }
  }

  @media (min-width: 1024px) {
    .front  { transform: translateZ(200px); }
    .back   { transform: rotateY(180deg) translateZ(200px); }
    .right  { transform: rotateY(90deg) translateZ(200px); }
    .left   { transform: rotateY(-90deg) translateZ(200px); }
    .top    { transform: rotateX(90deg) translateZ(200px); }
    .bottom { transform: rotateX(-90deg) translateZ(200px); }
  }

  @keyframes autoSpin {
    0% { transform: rotateY(0deg) rotateX(0deg); }
    100% { transform: rotateY(360deg) rotateX(360deg); }
  }
</style>