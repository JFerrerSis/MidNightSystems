---
import { ArrowDown } from 'lucide-astro';

interface Props {
  companyName: string;
  logoPath?: string;
}

const { companyName, logoPath = "/logodark.png" } = Astro.props;
const personalName = "Jorge Ferrer";
---

<header
  class="relative min-h-screen w-full flex items-center justify-center overflow-hidden bg-[#050505] px-4"
  id="hero-container"
>
  <div class="absolute inset-0 pointer-events-none" id="ambient-glows">
    <div class="absolute top-[15%] left-[-5%] w-72 h-72 bg-cyan-400/10 blur-[100px] rounded-full"></div>
    <div class="absolute bottom-[10%] right-[-5%] w-72 h-72 bg-pink-500/10 blur-[100px] rounded-full"></div>
  </div>

  <div class="relative z-10 flex flex-col items-center text-center w-full max-w-7xl" id="hero-main-content">
    
    <div class="relative mb-8 opacity-0" id="hero-logo">
      <img src={logoPath} alt="Logo" class="h-20 w-auto relative z-10" />
      <div class="absolute inset-0 bg-cyan-400 blur-2xl opacity-20 scale-150 rounded-full"></div>
    </div>

    <span id="hero-badge" class="opacity-0 mb-6 px-4 py-1.5 border border-cyan-500/30 bg-cyan-950/20 text-cyan-300 text-[10px] uppercase tracking-[0.25em] font-mono rounded-sm">
      {personalName} • Development & IT Support
    </span>

    <h1 class="text-white font-black tracking-tighter mb-8 perspective-distand">
      <span 
        id="main-title-text" 
        class="block text-5xl sm:text-7xl md:text-8xl lg:text-9xl leading-[0.9] bg-linear-to-b from-white to-gray-500 bg-clip-text text-transparent min-h-[1.1em]"
      ></span>

      <span id="sub-title" class="block text-[10px] sm:text-lg mt-4 tracking-[0.5em] uppercase text-pink-500 font-extralight opacity-0">
        Digital Experience
      </span>
    </h1>

    <p id="hero-desc" class="opacity-0 text-gray-400 text-sm sm:text-xl max-w-2xl mb-12 italic font-light">
      Elevamos el estándar de tu negocio con <span class="text-white font-medium">soluciones a medida</span>.
    </p>

    <div id="scroll-hint" class="opacity-0 flex flex-col items-center gap-2">
      <span class="text-[9px] uppercase tracking-[0.4em] text-white/50">Deslizar</span>
      <ArrowDown size={16} class="text-cyan-400 animate-bounce" />
    </div>
  </div>
</header>

<script>
  import { gsap } from "gsap";
  import { TextPlugin } from "gsap/TextPlugin";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(TextPlugin, ScrollTrigger);

  const company = "MidnightSystems"; 

  function initHero() {
    // 1. TIMELINE DE ENTRADA (Carga inicial)
    const entryTl = gsap.timeline({ defaults: { ease: "expo.out" } });

    gsap.set("#main-title-text", { rotationX: 45, opacity: 1 });

    entryTl.to("#hero-logo", { opacity: 1, y: 0, duration: 1.5, startAt: { y: 30 } })
      .to("#hero-badge", { opacity: 1, y: 0, duration: 1, startAt: { y: 20 } }, "-=1")
      .to("#main-title-text", {
        duration: 2,
        text: company,
        rotationX: 0,
        ease: "power3.inOut"
      }, "-=0.5")
      .to("#sub-title", { opacity: 1, y: 0, duration: 1, startAt: { y: 15 } }, "-=1")
      .to(["#hero-desc", "#scroll-hint"], { opacity: 1, y: 0, stagger: 0.2, duration: 1.2 }, "-=0.8");

    // 2. ANIMACIÓN DE SALIDA (Al hacer scroll hacia abajo)
    // Se sincroniza con el contenedor principal del index
    gsap.to("#hero-main-content", {
      scrollTrigger: {
        trigger: "#hero-container",
        start: "top top",      // Empieza cuando el hero está arriba
        end: "bottom top",     // Termina cuando el hero sale de pantalla
        scrub: true,           // Sincroniza con el movimiento del scroll
      },
      scale: 0.7,              // Se aleja
      opacity: 0,              // Se desvanece
      y: 100,                  // Cae un poco para dar profundidad
      filter: "blur(20px)",    // Se desenfoca
      ease: "none"
    });

    // 3. ANIMACIÓN DE LOS GLOWS (Sutil movimiento lateral en scroll)
    gsap.to("#ambient-glows", {
      scrollTrigger: {
        trigger: "#hero-container",
        start: "top top",
        end: "bottom top",
        scrub: true,
      },
      y: 200,
      opacity: 0,
      scale: 1.5
    });
  }

  window.addEventListener('load', initHero);
  // Soporte para Astro ViewTransitions
  document.addEventListener('astro:page-load', initHero);
</script>

<style>
  #hero-container {
    /* Aseguramos que el contenido sea pegajoso si el index lo requiere */
    perspective: 1200px;
  }

  #main-title-text {
    transform-style: preserve-3d;
    display: block;
    will-change: transform, opacity, filter;
  }

  #hero-main-content {
    will-change: transform, opacity, filter;
  }
</style>