---
interface Props {
  companyName: string;
  githubUser?: string;
  logoPath?: string;
}

const { companyName, githubUser, logoPath = "/logodark.png" } = Astro.props;
const personalName = "Jorge Ferrer";
---

<header
  class="relative min-h-screen w-full flex items-center justify-center overflow-hidden bg-[#050505] px-4 sm:px-6 md:px-8"
  id="hero-container"
>
  <div
    class="absolute inset-0 pointer-events-none select-none"
    id="hero-ambient-glows"
  >
    <div
      class="absolute top-[15%] left-[-5%] w-72 h-72 max-w-MD sm:h-112 bg-cyan-400/15 blur-[100px] rounded-full glow-pulse"
    >
    </div>
    <div
      class="absolute bottom-[10%] right-[-5%] w-72 h-72 max-w-MD sm:h-112 bg-pink-500/15 blur-[100px] rounded-full glow-pulse-delay"
    >
    </div>
  </div>

  <div
    class="relative z-10 flex flex-col items-center text-center w-full max-w-7xl"
    id="hero-content-wrapper"
  >
    <div class="relative mb-6 sm:mb-8" id="hero-logo-wrapper">
      <img
        src={logoPath}
        alt=`Logo de ${companyName}`
        class="h-16 sm:h-20 md:h-24 w-auto relative z-10 drop-shadow-[0_0_15px_rgba(255,255,255,0.1)]"
      />
      <div
        class="absolute inset-0 bg-cyan-400 blur-2xl opacity-20 scale-150 rounded-full z-0"
      >
      </div>
    </div>

    <div class="flex flex-col items-center w-full px-2">
      {/* TAG CON TU NOMBRE: Posicionamiento profesional */}
      <span
        class="mb-4 sm:mb-6 px-4 py-1.5 border border-cyan-500/30 bg-cyan-950/20 text-cyan-300 text-[9px] sm:text-xs uppercase tracking-[0.25em] font-mono rounded-sm"
      >
        {personalName} • Development & IT Support • Venezuela
      </span>

      <h1
        class="text-white font-black tracking-tighter mb-6 sm:mb-8 perspective-[1000px]"
      >
        <span
          class="block text-4xl sm:text-7xl md:text-8xl lg:text-9xl leading-[0.9] pb-2 bg-linear-to-b from-white to-gray-500 bg-clip-text text-transparent"
        >
          {companyName}
        </span>

        <span
          class="block text-[9px] sm:text-xs md:text-lg lg:text-xl mt-2 tracking-[0.3em] sm:tracking-[0.6em] uppercase text-pink-500 font-extralight opacity-90"
        >
          Digital Experience
        </span>
      </h1>

      <p
        class="text-gray-400 text-sm sm:text-xl max-w-[320px] sm:max-w-3xl leading-relaxed mb-10 font-light italic"
      >
        Elevamos el estándar de tu negocio con <strong class="text-white font-semibold italic">soluciones web a medida y soporte técnico de élite</strong>. Fusionamos la calidez del talento venezolano con una estética <strong class="text-white font-semibold">minimalista impecable</strong>.
      </p>

      <div class="flex flex-col items-center w-full">
        {
          githubUser ? (
            <div class="flex items-center gap-3 px-6 py-3 rounded-full bg-white/5 border border-white/10 backdrop-blur-xl">
              <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse" />
              <span class="text-gray-300 text-xs sm:text-sm">
                Lead Specialist: <strong class="text-white font-mono">{personalName}</strong>
              </span>
            </div>
          ) : (
            <div class="px-6 py-3 rounded-2xl bg-white/5 border border-cyan-500/20 backdrop-blur-xl flex items-center gap-3">
              <div class="w-1.5 h-1.5 rounded-full bg-cyan-400 shadow-[0_0_8px_#22d3ee] animate-pulse"></div>
              <code class="text-cyan-300 text-[10px] tracking-[0.3em] uppercase font-mono">
                {personalName} | Active Support
              </code>
            </div>
          )
        }
      </div>
    </div>
  </div>
</header>