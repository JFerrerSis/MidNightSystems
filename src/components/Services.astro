---
import { 
  Code2, 
  BookOpen, 
  Settings2, 
  MonitorCog,
  DownloadCloud,
  Layout,
  ArrowUpRight
} from 'lucide-astro';

const services = [
    {
        title: "Catálogos Digitales",
        category: "Web",
        description: "Experiencias interactivas para mostrar tus productos con enlaces de compra directos.",
        icon: BookOpen,
        color: "text-cyan-400",
        bgGlow: "bg-cyan-500/10",
        borderActive: "border-cyan-500/50",
        whatsappMsg: "Hola! Me interesa información sobre los Catálogos Digitales."
    },
    {
        title: "Webs & Portafolios",
        category: "Web",
        description: "Sitios de alto impacto visual diseñados para convertir y posicionar tu marca personal.",
        icon: Layout,
        color: "text-pink-500",
        bgGlow: "bg-pink-500/10",
        borderActive: "border-pink-500/50",
        whatsappMsg: "Hola! Quisiera cotizar una página web o portafolio."
    },
    {
        title: "Soporte Técnico IT",
        category: "Tech",
        description: "Resolución de errores, configuración de redes y asistencia remota o presencial.",
        icon: Settings2,
        color: "text-emerald-400",
        bgGlow: "bg-emerald-500/10",
        borderActive: "border-emerald-500/50",
        whatsappMsg: "Hola! Necesito soporte técnico para mi equipo."
    },
    {
        title: "Mantenimiento PC",
        category: "Tech",
        description: "Optimización profunda y limpieza de hardware para recuperar la velocidad de tu PC.",
        icon: MonitorCog,
        color: "text-blue-400",
        bgGlow: "bg-blue-500/10",
        borderActive: "border-blue-500/50",
        whatsappMsg: "Hola! Quisiera agendar un mantenimiento para mi PC."
    },
    {
        title: "Software & OS",
        category: "Tech",
        description: "Instalación limpia de Windows, Office y herramientas profesionales sin errores.",
        icon: DownloadCloud,
        color: "text-purple-400",
        bgGlow: "bg-purple-500/10",
        borderActive: "border-purple-500/50",
        whatsappMsg: "Hola! Necesito ayuda instalando software o un sistema operativo."
    },
    {
        title: "Landing Pages",
        category: "Web",
        description: "Estructuras de una sola página optimizadas para campañas de ventas específicas.",
        icon: Code2,
        color: "text-yellow-400",
        bgGlow: "bg-yellow-500/10",
        borderActive: "border-yellow-500/50",
        whatsappMsg: "Hola! Me interesa una Landing Page para mi negocio."
    }
];

const whatsappBase = "https://wa.me/584240000000?text=";
---

<section class="py-32 px-4 sm:px-6 lg:px-8 bg-[#0a0a0b] relative overflow-hidden" id="services-section">
    <div class="absolute top-0 right-0 w-125 h-125 bg-cyan-500/5 blur-[120px] rounded-full pointer-events-none anim-glow"></div>
    <div class="absolute bottom-0 left-0 w-125 h-125 bg-purple-500/5 blur-[120px] rounded-full pointer-events-none anim-glow"></div>

    <div class="max-w-7xl mx-auto relative z-10">
        <div class="mb-20 space-y-4" id="services-header">
            <div class="flex items-center gap-3 overflow-hidden">
                <span class="w-12 h-px bg-cyan-500 anim-line"></span>
                <span class="text-cyan-500 font-mono text-[10px] uppercase tracking-[0.5em] anim-tag">Especialidades</span>
            </div>
            <h2 class="text-white text-5xl md:text-6xl font-black tracking-tighter uppercase italic anim-title">
                Servicios <span class="text-white/10">Expertos</span>
            </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8" id="services-grid">
            {services.map((service) => (
                <div class={`service-card group relative p-px rounded-[2.5rem] bg-white/5 border border-white/10 transition-all duration-500 hover:scale-[1.02] hover:${service.borderActive}`}>
                    
                    <div class={`absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700 blur-2xl ${service.bgGlow} pointer-events-none`}></div>

                    <div class="relative z-10 p-10 flex flex-col h-full bg-[#111112]/90 backdrop-blur-xl rounded-[calc(2.5rem-1px)] overflow-hidden">
                        
                        <div class={`absolute -top-10 -right-10 w-32 h-32 rounded-full blur-3xl opacity-0 group-hover:opacity-20 transition-opacity duration-700 ${service.bgGlow.replace('/10', '/40')}`}></div>

                        <div class="flex justify-between items-start mb-10">
                            <div class={`p-4 rounded-2xl bg-white/5 border border-white/10 shadow-2xl transition-all duration-500 group-hover:rotate-10 group-hover:scale-110 ${service.color}`}>
                                <service.icon size={28} strokeWidth={1.5} />
                            </div>
                            <span class="text-[9px] font-mono text-gray-500 uppercase tracking-widest bg-white/5 px-3 py-1.5 rounded-full border border-white/5">
                                {service.category}
                            </span>
                        </div>
                        
                        <h3 class="text-white text-2xl font-bold mb-4 tracking-tight group-hover:text-cyan-300 transition-colors">
                            {service.title}
                        </h3>
                        
                        <p class="text-gray-400 text-sm leading-relaxed font-light mb-10 grow italic">
                            {service.description}
                        </p>

                        <a 
                            href={`${whatsappBase}${encodeURIComponent(service.whatsappMsg)}`}
                            target="_blank"
                            class={`inline-flex items-center gap-3 text-[10px] font-black uppercase tracking-[0.2em] transition-all no-underline
                            ${service.color} sm:text-gray-400 sm:group-hover:${service.color}`}
                        >
                            <span>Consultar Ahora</span>
                            <div class={`p-2 rounded-full bg-white/5 group-hover:bg-current transition-all`}>
                                <ArrowUpRight size={14} class="group-hover:text-black transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" />
                            </div>
                        </a>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    function initServices() {
        // 1. Animación del Header
        const headerTl = gsap.timeline({
            scrollTrigger: {
                trigger: "#services-header",
                start: "top 85%",
            }
        });

        headerTl
            .from(".anim-line", { width: 0, duration: 1, ease: "expo.out" })
            .from(".anim-tag", { x: -20, opacity: 0, duration: 0.8 }, "-=0.6")
            .from(".anim-title", { y: 30, opacity: 0, duration: 1, ease: "power4.out" }, "-=0.6");

        // 2. Animación de las Tarjetas (Entrada en cascada)
        gsap.from(".service-card", {
            scrollTrigger: {
                trigger: "#services-grid",
                start: "top 80%",
            },
            y: 60,
            opacity: 0,
            scale: 0.9,
            stagger: 0.15,
            duration: 1.2,
            ease: "expo.out",
        });

        // 3. Parallax sutil de los fondos de luces
        gsap.to(".anim-glow", {
            y: -50,
            x: 30,
            duration: 10,
            repeat: -1,
            yoyo: true,
            ease: "sine.inOut"
        });
    }

    document.addEventListener('astro:page-load', initServices);
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
        initServices();
    }
</script>

<style>
    .service-card {
        will-change: transform, opacity;
    }

    /* Efecto de cristal esmerilado solo en hover para PC */
    @media (min-width: 1024px) {
        .service-card:hover .backdrop-blur-xl {
            backdrop-blur: 40px;
        }
    }

    /* En móvil, los iconos y textos de acción tienen color siempre para guiar el ojo */
    @media (max-width: 640px) {
        .service-card {
            background: #111112;
            border-color: rgba(255, 255, 255, 0.1);
        }
    }
</style>