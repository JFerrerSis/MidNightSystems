---
import { 
  Code2, BookOpen, Settings2, MonitorCog,
  DownloadCloud, Layout, ArrowUpRight, Mail, MessageSquare, X
} from 'lucide-astro';

const phone = import.meta.env.PUBLIC_WHATSAPP_NUMBER || "584240000000";

const services = [
    { title: "Catálogos Digitales", category: "Web", icon: BookOpen, color: "text-cyan-400", bgGlow: "#22d3ee" },
    { title: "Webs & Portafolios", category: "Web", icon: Layout, color: "text-pink-500", bgGlow: "#ec4899" },
    { title: "Soporte Técnico IT", category: "Tech", icon: Settings2, color: "text-emerald-400", bgGlow: "#10b981" },
    { title: "Mantenimiento PC", category: "Tech", icon: MonitorCog, color: "text-blue-400", bgGlow: "#60a5fa" },
    { title: "Software & OS", category: "Tech", icon: DownloadCloud, color: "text-purple-400", bgGlow: "#a855f7" },
    { title: "Landing Pages", category: "Web", icon: Code2, color: "text-yellow-400", bgGlow: "#eab308" }
];
---

<section class="py-24 px-4 sm:px-6 relative overflow-hidden bg-transparent" id="services-section">
    <div class="absolute inset-0 pointer-events-none opacity-20">
        <div class="absolute top-0 left-1/4 w-96 h-96 bg-cyan-500/20 rounded-full blur-[120px] liquid-glow"></div>
        <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-purple-500/20 rounded-full blur-[120px] liquid-glow"></div>
    </div>

    <div class="max-w-6xl mx-auto relative z-10">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-20 gap-4 overflow-hidden" id="services-header">
            <div class="space-y-2">
                <div class="flex items-center gap-3 anim-service-item">
                    <span class="w-8 h-px bg-cyan-500"></span>
                    <span class="text-cyan-500 font-mono text-[10px] uppercase tracking-[0.4em]">Especialidades</span>
                </div>
                <h2 class="text-white text-4xl md:text-6xl font-black uppercase tracking-tighter anim-service-item">
                    Soluciones <span class="text-outline text-transparent not-italic opacity-30">Expertas.</span>
                </h2>
            </div>
            <p class="text-gray-500 text-[11px] max-w-60 font-light italic leading-relaxed border-l border-white/10 pl-4 anim-service-item">
                Infraestructura y diseño de alto rendimiento para marcas digitales.
            </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 perspective-1000" id="services-grid">
            {services.map((service) => (
                <div class="service-card-wrapper h-full anim-service-item">
                    <button 
                        data-service={service.title}
                        class="service-btn service-card group relative block w-full text-left p-px rounded-3xl bg-white/5 border border-white/10 no-underline transition-all duration-500"
                        style={`--glow-color: ${service.bgGlow}`}
                    >
                        <div class="relative z-10 p-8 flex flex-col h-full bg-[#0d0d0f]/80 backdrop-blur-2xl rounded-[calc(1.8rem-1px)] overflow-hidden">
                            <div class="absolute inset-0 bg-linear-to-br from-white/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
                            
                            <div class="flex justify-between items-start mb-10 relative z-20">
                                <div class="p-4 rounded-xl bg-white/5 border border-white/10 transition-all duration-500 sm:group-hover:scale-110 sm:group-hover:-rotate-3 icon-box">
                                    <service.icon size={26} class={`${service.color}`} strokeWidth={1.5} />
                                </div>
                                <ArrowUpRight size={18} class="text-white/20 group-hover:text-white group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-all" />
                            </div>

                            <div class="space-y-1 mt-auto relative z-20">
                                <span class="text-[10px] font-mono text-gray-500 uppercase tracking-widest block">{service.category}</span>
                                <h3 class="text-white text-2xl font-bold tracking-tight uppercase group-hover:text-white transition-colors">
                                    {service.title}
                                </h3>
                            </div>
                        </div>
                    </button>
                </div>
            ))}
        </div>
    </div>

    <div id="contact-modal" class="fixed inset-0 z-200 flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-300">
        <div class="absolute inset-0 bg-black/95 backdrop-blur-xl" id="modal-overlay"></div>
        <div class="relative w-full max-w-sm bg-[#0d0d0f] border border-white/10 rounded-[2.5rem] p-8 shadow-2xl scale-90 transition-transform duration-300" id="modal-content">
            <button class="absolute top-6 right-6 text-gray-500 hover:text-white transition-colors" id="close-modal">
                <X size={20} />
            </button>
            <div class="text-center mb-8">
                <span class="text-cyan-500 font-mono text-[9px] uppercase tracking-[0.4em] block mb-2">Canal de atención</span>
                <h4 id="modal-service-title" class="text-white text-2xl font-black uppercase tracking-tighter">Servicio</h4>
            </div>
            <div class="grid grid-cols-1 gap-4">
                <a id="link-whatsapp" target="_blank" class="flex items-center justify-between p-5 rounded-2xl bg-emerald-500/5 border border-emerald-500/20 hover:bg-emerald-500/10 hover:border-emerald-500/40 transition-all group">
                    <div class="flex items-center gap-4">
                        <MessageSquare class="text-emerald-500" size={24} />
                        <span class="text-white font-bold text-sm uppercase tracking-widest">WhatsApp</span>
                    </div>
                    <ArrowUpRight size={16} class="text-emerald-500 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" />
                </a>
                <button id="btn-go-to-contact" class="flex items-center justify-between p-5 rounded-2xl bg-blue-500/5 border border-blue-500/20 hover:bg-blue-500/10 hover:border-blue-500/40 transition-all group w-full text-left">
                    <div class="flex items-center gap-4">
                        <Mail class="text-blue-500" size={24} />
                        <span class="text-white font-bold text-sm uppercase tracking-widest">Correo / Form</span>
                    </div>
                    <ArrowUpRight size={16} class="text-blue-500 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" />
                </button>
            </div>
        </div>
    </div>
</section>

<style>
    .text-outline { -webkit-text-stroke: 1px rgba(255, 255, 255, 0.2); }
    .service-card { transform-style: preserve-3d; will-change: transform, opacity, box-shadow; }
    #contact-modal.active { opacity: 1; pointer-events: auto; }
    #contact-modal.active #modal-content { transform: scale(1); }
    .liquid-glow { animation: move 12s ease-in-out infinite; }
    @keyframes move {
        0%, 100% { transform: translate(0, 0) scale(1); }
        50% { transform: translate(30px, -30px) scale(1.1); }
    }
</style>

<script define:vars={{ phone }}>
    const modal = document.getElementById('contact-modal');
    const modalTitle = document.getElementById('modal-service-title');
    const linkWhatsapp = document.getElementById('link-whatsapp');
    const btnGoContact = document.getElementById('btn-go-to-contact');
    const closeBtn = document.getElementById('close-modal');
    const overlay = document.getElementById('modal-overlay');

    window.openServiceModal = (serviceName) => {
        const message = encodeURIComponent(`Hola Jorge! Me interesa información sobre: ${serviceName}`);
        modalTitle.innerText = serviceName;
        linkWhatsapp.href = `https://wa.me/${phone}?text=${message}`;
        btnGoContact.dataset.selectedService = serviceName;
        modal.classList.add('active');
    };

    const closeModal = () => modal.classList.remove('active');
    closeBtn?.addEventListener('click', closeModal);
    overlay?.addEventListener('click', closeModal);
</script>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import { ScrollToPlugin } from "gsap/ScrollToPlugin";

    gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);

    function initServices() {
        // --- 1. ANIMACIÓN DE ENTRADA/SALIDA COHERENTE ---
        gsap.from(".anim-service-item", {
            y: 80,
            opacity: 0,
            scale: 0.9,
            filter: "blur(15px)",
            duration: 1,
            stagger: 0.1,
            ease: "expo.out",
            scrollTrigger: {
                trigger: "#services-section",
                start: "top 80%", // Dispara un poco antes para fluidez
                end: "bottom 20%",
                toggleActions: "play reverse play reverse",
            }
        });

        // --- 2. LOGICA DE INTERACCIÓN ---
        document.querySelectorAll('.service-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const service = btn.getAttribute('data-service');
                (window as any).openServiceModal(service);
            });
        });

        const btnGoContact = document.getElementById('btn-go-to-contact');
        btnGoContact?.addEventListener('click', () => {
            document.getElementById('contact-modal')?.classList.remove('active');
            
            gsap.to(window, {
                duration: 1.5,
                scrollTo: {
                    y: "#contact-section",
                    autoKill: false
                },
                ease: "power4.inOut"
            });

            const subjectField = document.querySelector('input[name="asunto"]');
            if (subjectField) {
                (subjectField as HTMLInputElement).value = `Consulta: ${btnGoContact.dataset.selectedService}`;
            }
        });

        // --- 3. TILT 3D ---
        if (window.matchMedia("(min-width: 1024px)").matches) {
            document.querySelectorAll(".service-card-wrapper").forEach((wrapper) => {
                const card = wrapper.querySelector(".service-card");
                wrapper.addEventListener("mousemove", (e: any) => {
                    const rect = wrapper.getBoundingClientRect();
                    const x = e.clientX - rect.left - rect.width / 2;
                    const y = e.clientY - rect.top - rect.height / 2;
                    gsap.to(card, { rotateY: x * 0.08, rotateX: -y * 0.08, scale: 1.02, duration: 0.5 });
                });
                wrapper.addEventListener("mouseleave", () => {
                    gsap.to(card, { rotateX: 0, rotateY: 0, scale: 1, duration: 0.7 });
                });
            });
        }
    }

    // Ejecutar con un pequeño delay para asegurar que el DOM y el Hero estén listos
    document.addEventListener("astro:page-load", () => {
        setTimeout(initServices, 50);
    });
    
    // Fallback carga inicial
    if (document.readyState !== 'loading') {
        setTimeout(initServices, 50);
    }
</script>