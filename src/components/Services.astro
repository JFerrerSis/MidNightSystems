---
import { 
  Code2, 
  BookOpen, 
  Settings2, 
  MonitorCog,
  DownloadCloud,
  Layout,
  ArrowUpRight
} from 'lucide-astro';

const services = [
    {
        title: "Catálogos Digitales",
        category: "Web",
        description: "Experiencias interactivas para mostrar tus productos con enlaces de compra directos.",
        icon: BookOpen,
        color: "text-cyan-400",
        shadow: "group-hover:shadow-[0_0_40px_-10px_rgba(34,211,238,0.2)]",
        border: "group-hover:border-cyan-500/50",
        whatsappMsg: "Hola! Me interesa información sobre los Catálogos Digitales."
    },
    {
        title: "Webs & Portafolios",
        category: "Web",
        description: "Sitios de alto impacto visual diseñados para convertir y posicionar tu marca personal.",
        icon: Layout,
        color: "text-pink-500",
        shadow: "group-hover:shadow-[0_0_40px_-10px_rgba(236,72,153,0.2)]",
        border: "group-hover:border-pink-500/50",
        whatsappMsg: "Hola! Quisiera cotizar una página web o portafolio."
    },
    {
        title: "Soporte Técnico IT",
        category: "Tech",
        description: "Resolución de errores, configuración de redes y asistencia remota o presencial.",
        icon: Settings2,
        color: "text-emerald-400",
        shadow: "group-hover:shadow-[0_0_40px_-10px_rgba(52,211,153,0.2)]",
        border: "group-hover:border-emerald-500/50",
        whatsappMsg: "Hola! Necesito soporte técnico para mi equipo."
    },
    {
        title: "Mantenimiento PC",
        category: "Tech",
        description: "Optimización profunda y limpieza de hardware para recuperar la velocidad de tu PC.",
        icon: MonitorCog,
        color: "text-blue-400",
        shadow: "group-hover:shadow-[0_0_40px_-10px_rgba(96,165,250,0.2)]",
        border: "group-hover:border-blue-500/50",
        whatsappMsg: "Hola! Quisiera agendar un mantenimiento para mi PC."
    },
    {
        title: "Software & OS",
        category: "Tech",
        description: "Instalación limpia de Windows, Office y herramientas profesionales sin errores.",
        icon: DownloadCloud,
        color: "text-purple-400",
        shadow: "group-hover:shadow-[0_0_40px_-10px_rgba(192,132,252,0.2)]",
        border: "group-hover:border-purple-500/50",
        whatsappMsg: "Hola! Necesito ayuda instalando software o un sistema operativo."
    },
    {
        title: "Landing Pages",
        category: "Web",
        description: "Estructuras de una sola página optimizadas para campañas de ventas específicas.",
        icon: Code2,
        color: "text-yellow-400",
        shadow: "group-hover:shadow-[0_0_40px_-10px_rgba(250,204,21,0.2)]",
        border: "group-hover:border-yellow-500/50",
        whatsappMsg: "Hola! Me interesa una Landing Page para mi negocio."
    }
];

const whatsappBase = "https://wa.me/584240000000?text=";
---

<section class="py-24 px-4 sm:px-6 lg:px-8 bg-[#050505] relative overflow-hidden" id="services-section">
    <div class="max-w-7xl mx-auto">
        <div class="mb-16 text-center lg:text-left reveal-center">
            <span class="text-cyan-500 font-mono text-xs uppercase tracking-[0.3em] mb-4 block">Especialidades</span>
            <h2 class="text-white text-4xl md:text-5xl font-black tracking-tighter">
                Servicios <span class="text-gray-600 font-light">Efectivos.</span>
            </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="services-grid">
            {services.map((service) => (
                <div class={`service-card group relative p-px rounded-3xl overflow-hidden border border-white/5 bg-white/2 transition-all duration-700 ease-out ${service.shadow} ${service.border}`}>
                    
                    <div class="spotlight pointer-events-none absolute inset-0 z-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500" 
                         style="background: radial-gradient(600px circle at var(--x) var(--y), rgba(255,255,255,0.06), transparent 40%);">
                    </div>

                    <div class="relative z-10 p-8 flex flex-col h-full bg-[#080808] rounded-[calc(1.5rem-1px)]">
                        <div class="flex justify-between items-start mb-8">
                            <div class={`p-3 rounded-2xl bg-white/5 border border-white/10 transition-all duration-500 group-hover:scale-110 ${service.color}`}>
                                <service.icon size={24} strokeWidth={1.5} />
                            </div>
                            <span class="text-[10px] font-mono text-gray-500 uppercase tracking-widest border border-white/5 px-2 py-1 rounded">
                                {service.category}
                            </span>
                        </div>
                        
                        <h3 class="text-white text-xl font-bold mb-3 tracking-tight">
                            {service.title}
                        </h3>
                        
                        <p class="text-gray-400 text-sm leading-relaxed font-light mb-8 grow">
                            {service.description}
                        </p>

                        <a 
                            href={`${whatsappBase}${encodeURIComponent(service.whatsappMsg)}`}
                            target="_blank"
                            class={`inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest transition-all ${service.color} lg:text-white lg:group-hover:${service.color}`}
                        >
                            Consultar Ahora
                            <ArrowUpRight size={14} class="transition-transform group-hover:translate-x-1 group-hover:-translate-y-1" />
                        </a>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    function initServices() {
        const cards = document.querySelectorAll(".service-card");
        
        cards.forEach((card) => {
            // 1. ANIMACIÓN DE ENTRADA (Aparecer desde el medio)
            // Cambiamos toggleActions para que maneje la re-entrada al subir
            gsap.fromTo(card, 
                { 
                    opacity: 0, 
                    scale: 0.5, 
                    filter: "blur(10px)"
                },
                {
                    opacity: 1,
                    scale: 1,
                    filter: "blur(0px)",
                    duration: 1.2,
                    ease: "elastic.out(1, 0.8)",
                    scrollTrigger: {
                        trigger: card,
                        start: "top 90%",
                        end: "bottom 10%",
                        // play: al bajar, entra
                        // reverse: al subir y salir por abajo, se oculta
                        // restart: al subir y re-entrar desde abajo, vuelve a animar
                        toggleActions: "play reverse restart reverse" 
                    }
                }
            );

            // 2. ANIMACIÓN DE SALIDA (Se aleja al seguir bajando)
            // Esta se mantiene con scrub porque es un efecto ligado al movimiento del mouse/scroll
            gsap.to(card, {
                scrollTrigger: {
                    trigger: card,
                    start: "top 15%", // Empieza a desvanecerse antes de tocar el tope
                    end: "top top",
                    scrub: true,
                },
                scale: 0.6,
                opacity: 0,
                filter: "blur(20px)",
                y: -100, // Añadimos un pequeño desplazamiento hacia arriba para el efecto de alejamiento
                ease: "none"
            });

            // 3. LÓGICA SPOTLIGHT (Sin cambios)
            card.addEventListener("mousemove", (e: any) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                (card as HTMLElement).style.setProperty("--x", `${x}px`);
                (card as HTMLElement).style.setProperty("--y", `${y}px`);
            });
        });
    }

    window.addEventListener('load', initServices);
    document.addEventListener('astro:page-load', initServices);
</script>

<style>
    .service-card {
        will-change: transform, opacity, filter;
        /* CRÍTICO: Abre desde el centro exacto */
        transform-origin: center center;
    }
    
    .reveal-center {
        transform-origin: center;
    }

    .spotlight {
        --x: 0px;
        --y: 0px;
    }
</style>