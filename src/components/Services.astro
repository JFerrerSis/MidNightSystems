---
import { 
  Code2, BookOpen, Settings2, MonitorCog,
  DownloadCloud, Layout, ArrowUpRight
} from 'lucide-astro';

const services = [
    {
        title: "Catálogos Digitales",
        category: "Web",
        description: "Experiencias interactivas para mostrar tus productos con enlaces de compra directos.",
        icon: BookOpen,
        color: "text-cyan-400",
        bgGlow: "bg-cyan-500/10",
        borderActive: "border-cyan-500/50",
        whatsappMsg: "Hola! Me interesa información sobre los Catálogos Digitales."
    },
    {
        title: "Webs & Portafolios",
        category: "Web",
        description: "Sitios de alto impacto visual diseñados para convertir y posicionar tu marca personal.",
        icon: Layout,
        color: "text-pink-500",
        bgGlow: "bg-pink-500/10",
        borderActive: "border-pink-500/50",
        whatsappMsg: "Hola! Quisiera cotizar una página web o portafolio."
    },
    {
        title: "Soporte Técnico IT",
        category: "Tech",
        description: "Resolución de errores, configuración de redes y asistencia remota o presencial.",
        icon: Settings2,
        color: "text-emerald-400",
        bgGlow: "bg-emerald-500/10",
        borderActive: "border-emerald-500/50",
        whatsappMsg: "Hola! Necesito soporte técnico para mi equipo."
    },
    {
        title: "Mantenimiento PC",
        category: "Tech",
        description: "Optimización profunda y limpieza de hardware para recuperar la velocidad de tu PC.",
        icon: MonitorCog,
        color: "text-blue-400",
        bgGlow: "bg-blue-500/10",
        borderActive: "border-blue-500/50",
        whatsappMsg: "Hola! Quisiera agendar un mantenimiento para mi PC."
    },
    {
        title: "Software & OS",
        category: "Tech",
        description: "Instalación limpia de Windows, Office y herramientas profesionales sin errores.",
        icon: DownloadCloud,
        color: "text-purple-400",
        bgGlow: "bg-purple-500/10",
        borderActive: "border-purple-500/50",
        whatsappMsg: "Hola! Necesito ayuda instalando software o un sistema operativo."
    },
    {
        title: "Landing Pages",
        category: "Web",
        description: "Estructuras de una sola página optimizadas para campañas de ventas específicas.",
        icon: Code2,
        color: "text-yellow-400",
        bgGlow: "bg-yellow-500/10",
        borderActive: "border-yellow-500/50",
        whatsappMsg: "Hola! Me interesa una Landing Page para mi negocio."
    }
];

const whatsappBase = "https://wa.me/584240000000?text=";
---

<section class="py-32 px-4 sm:px-6 lg:px-8 bg-[#0a0a0b] relative overflow-hidden" id="services-section">
    <div class="absolute top-0 right-0 w-125 h-125 bg-cyan-500/5 blur-[120px] rounded-full pointer-events-none anim-glow-bg"></div>
    <div class="absolute bottom-0 left-0 w-125 h-125 bg-purple-500/5 blur-[120px] rounded-full pointer-events-none anim-glow-bg"></div>

    <div class="max-w-7xl mx-auto relative z-10">
        <div class="mb-24 space-y-4" id="services-header">
            <div class="flex items-center gap-3 overflow-hidden">
                <span class="w-12 h-px bg-cyan-500 anim-line"></span>
                <span class="text-cyan-500 font-mono text-[10px] uppercase tracking-[0.5em] anim-tag">Especialidades</span>
            </div>
            <h2 class="text-white text-5xl md:text-7xl font-black tracking-tighter uppercase italic anim-title leading-none">
                Servicios <span class="text-white/10">Expertos</span>
            </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-10" id="services-grid">
            {services.map((service) => (
                <div class={`service-card group relative p-px rounded-[2.5rem] bg-white/5 border border-white/10 transition-all duration-500 hover:scale-[1.02] hover:${service.borderActive}`}>
                    <div class={`absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700 blur-2xl ${service.bgGlow} pointer-events-none`}></div>
                    <div class="relative z-10 p-10 flex flex-col h-full bg-[#111112]/90 backdrop-blur-xl rounded-[calc(2.5rem-1px)] overflow-hidden">
                        <div class="flex justify-between items-start mb-10">
                            <div class={`p-4 rounded-2xl bg-white/5 border border-white/10 shadow-2xl transition-all duration-500 group-hover:rotate-12 group-hover:scale-110 ${service.color}`}>
                                <service.icon size={32} strokeWidth={1.5} />
                            </div>
                            <span class="text-[9px] font-mono text-gray-500 uppercase tracking-widest bg-white/5 px-3 py-1.5 rounded-full border border-white/5">
                                {service.category}
                            </span>
                        </div>
                        <h3 class="text-white text-2xl font-bold mb-4 tracking-tight group-hover:text-cyan-300 transition-colors uppercase">
                            {service.title}
                        </h3>
                        <p class="text-gray-400 text-sm leading-relaxed font-light mb-10 grow italic opacity-80 group-hover:opacity-100 transition-opacity">
                            {service.description}
                        </p>
                        <a 
                            href={`${whatsappBase}${encodeURIComponent(service.whatsappMsg)}`}
                            target="_blank"
                            class={`inline-flex items-center gap-3 text-[10px] font-black uppercase tracking-[0.2em] transition-all no-underline ${service.color} lg:text-gray-400 lg:group-hover:${service.color}`}
                        >
                            <span>Consultar Ahora</span>
                            <div class="p-2.5 rounded-full bg-white/5 group-hover:bg-current transition-all duration-300">
                                <ArrowUpRight size={14} class="group-hover:text-black transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" />
                            </div>
                        </a>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<style>
    .service-card {
        will-change: transform, opacity;
        opacity: 0; /* Estado inicial para evitar parpadeo */
    }
    .text-white\/10 { -webkit-text-stroke: 1px rgba(255, 255, 255, 0.05); }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    function init() {
        // 1. Limpiar todo rastro de animaciones anteriores
        ScrollTrigger.getAll().forEach(st => st.kill());

        // 2. Animación Header (Ida y Vuelta)
        const header = document.querySelector("#services-header");
        if(header) {
            gsap.fromTo(header.querySelectorAll(".anim-line, .anim-tag, .anim-title"), 
                { y: 50, opacity: 0 },
                {
                    y: 0, opacity: 1,
                    stagger: 0.1,
                    scrollTrigger: {
                        trigger: header,
                        start: "top 95%",
                        end: "top 75%",
                        scrub: 1,
                        toggleActions: "play reverse play reverse",
                    }
                }
            );
        }

        // 3. Animación de Tarjetas (Ida y Vuelta Real)
        const cards = document.querySelectorAll(".service-card");
        cards.forEach((card) => {
            gsap.fromTo(card, 
                { 
                    y: 100, 
                    opacity: 0, 
                    scale: 0.9,
                },
                {
                    y: 0, 
                    opacity: 1, 
                    scale: 1,
                    scrollTrigger: {
                        trigger: card,
                        start: "top 100%", // Empieza al asomar
                        end: "top 70%",   // Se completa rápido
                        scrub: 1,
                        // El secreto: play al bajar, reverse al subir
                        toggleActions: "play reverse play reverse",
                        invalidateOnRefresh: true,
                    }
                }
            );
        });

        // 4. Animación de los Glows de fondo (Bucle infinito independiente)
        gsap.to(".anim-glow-bg", {
            y: "random(-50, 50)",
            x: "random(-30, 30)",
            duration: 5,
            repeat: -1,
            yoyo: true,
            ease: "sine.inOut"
        });

        ScrollTrigger.refresh();
    }

    // Asegurar ejecución en cambios de página de Astro
    document.addEventListener('astro:page-load', init);
    // Ejecución inicial
    init();
</script>